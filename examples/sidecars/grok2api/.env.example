# grok2api sidecar example env.
# Copy to .env next to docker-compose.yml and edit locally. Do not commit real secrets.

GROK2API_IMAGE=ghcr.io/chenyme/grok2api:latest
GROK2API_BIND=127.0.0.1:8000
TZ=Asia/Shanghai
LOG_LEVEL=INFO
SERVER_WORKERS=1
ACCOUNT_STORAGE=local

# Hermes provider-proxy profile .env should use the grok2api API key as OPENAI_API_KEY.
# OPENAI_API_KEY=<same value as grok2api app.api_key, if configured>
# API_SERVER_KEY=<Bearer key clients use when calling Hermes API Server>
