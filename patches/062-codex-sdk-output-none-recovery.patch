+class TestCodexAdapterNullOutputRecovery:
+    class _FakeStream:
+        def __init__(self, events=(), *, final_response=None, final_error=None, iter_error=None):
+            self._events = list(events)
+            self._final_response = final_response
+            self._final_error = final_error
+            self._iter_error = iter_error
+
+        def __enter__(self):
+            return self
+
+        def __exit__(self, *a):
+            return False
+
+        def __iter__(self):
+            for event in self._events:
+                yield event
+            if self._iter_error is not None:
+                raise self._iter_error
+
+        def get_final_response(self):
+            if self._final_error is not None:
+                raise self._final_error
+            return self._final_response
+
+    @staticmethod
+    def _adapter_for_stream(stream):
+        real_client = MagicMock()
+        real_client.responses.stream = lambda **kwargs: stream
+        return _CodexCompletionsAdapter(real_client, "gpt-5.3-codex")
+
+    def test_backfills_empty_output_preserving_usage(self):
+        output_item = SimpleNamespace(
+            type="message",
+            content=[SimpleNamespace(type="output_text", text="aux stream item")],
+        )
+        final_response = SimpleNamespace(
+            output=[],
+            usage=SimpleNamespace(input_tokens=11, output_tokens=6, total_tokens=17),
+        )
+        adapter = self._adapter_for_stream(self._FakeStream(
+            [SimpleNamespace(type="response.output_item.done", item=output_item)],
+            final_response=final_response,
+        ))
+
+        response = adapter.create(messages=[{"role": "user", "content": "hi"}])
+
+        assert response.choices[0].message.content == "aux stream item"
+        assert response.usage.prompt_tokens == 11
+        assert response.usage.completion_tokens == 6
+        assert response.usage.total_tokens == 17
+
+    def test_backfills_none_output_preserving_usage(self):
+        output_item = SimpleNamespace(
+            type="message",
+            content=[SimpleNamespace(type="output_text", text="aux none item")],
+        )
+        final_response = SimpleNamespace(
+            output=None,
+            usage=SimpleNamespace(input_tokens=4, output_tokens=3, total_tokens=7),
+        )
+        adapter = self._adapter_for_stream(self._FakeStream(
+            [SimpleNamespace(type="response.output_item.done", item=output_item)],
+            final_response=final_response,
+        ))
+
+        response = adapter.create(messages=[{"role": "user", "content": "hi"}])
+
+        assert response.choices[0].message.content == "aux none item"
+        assert response.usage.prompt_tokens == 4
+        assert response.usage.completion_tokens == 3
+        assert response.usage.total_tokens == 7
+
+    def test_reraises_original_typeerror_when_nothing_to_recover(self):
+        original_error = TypeError("'NoneType' object is not iterable")
+        adapter = self._adapter_for_stream(self._FakeStream(final_error=original_error))
+
+        with pytest.raises(TypeError) as exc_info:
+            adapter.create(messages=[{"role": "user", "content": "hi"}])
+
+        assert exc_info.value is original_error
+
+    def test_recovers_missing_completed_runtime_error_from_text_deltas(self):
+        original_error = RuntimeError("Didn't receive a `response.completed` event.")
+        adapter = self._adapter_for_stream(self._FakeStream(
+            [SimpleNamespace(type="response.output_text.delta", delta="Recovered title")],
+            final_error=original_error,
+        ))
+
+        response = adapter.create(messages=[{"role": "user", "content": "hi"}])
+
+        assert response.choices[0].message.content == "Recovered title"
+
