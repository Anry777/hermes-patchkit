index 000000000..5b51bd8e0
--- /dev/null
+++ b/web/src/pages/ProfilesPage.tsx
@@ -0,0 +1,366 @@
+import {
+  useCallback,
+  useEffect,
+  useLayoutEffect,
+  useMemo,
+  useState,
+  type ComponentType,
+} from "react";
+import { useSearchParams } from "react-router-dom";
+import {
+  Bot,
+  CheckCircle2,
+  CircleDot,
+  FileText,
+  Folder,
+  KeyRound,
+  MessageSquare,
+  RefreshCw,
+  Terminal,
+} from "lucide-react";
+import { Badge, Button, Spinner } from "@nous-research/ui";
+
+import {
+  api,
+  type DashboardProfileDetail,
+  type DashboardProfileSummary,
+} from "@/lib/api";
+import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
+import { usePageHeader } from "@/contexts/usePageHeader";
+import { useI18n } from "@/i18n";
+import { cn } from "@/lib/utils";
+import { PluginSlot } from "@/plugins";
+
+export default function ProfilesPage() {
+  const [searchParams, setSearchParams] = useSearchParams();
+  const [profiles, setProfiles] = useState<DashboardProfileSummary[]>([]);
+  const [activeProfile, setActiveProfile] = useState<string | null>(null);
+  const [selectedDetail, setSelectedDetail] = useState<DashboardProfileDetail | null>(null);
+  const [loading, setLoading] = useState(true);
+  const [detailLoading, setDetailLoading] = useState(false);
+  const [error, setError] = useState<string | null>(null);
+  const [detailError, setDetailError] = useState<string | null>(null);
+  const { setAfterTitle, setEnd } = usePageHeader();
+  const { t } = useI18n();
+
+  const selectedName = useMemo(() => {
+    const fromQuery = searchParams.get("profile");
+    if (fromQuery && profiles.some((profile) => profile.name === fromQuery)) {
+      return fromQuery;
+    }
+    return activeProfile ?? profiles.find((profile) => profile.is_active)?.name ?? profiles[0]?.name ?? "";
+  }, [activeProfile, profiles, searchParams]);
+
+  const loadProfiles = useCallback(() => {
+    setLoading(true);
+    setError(null);
+    api.getDashboardProfiles()
+      .then((resp) => {
+        setProfiles(resp.profiles);
+        setActiveProfile(resp.active_profile);
+      })
+      .catch((err: unknown) => setError(String(err)))
+      .finally(() => setLoading(false));
+  }, []);
+
+  useEffect(() => {
+    const timeout = window.setTimeout(loadProfiles, 0);
+    return () => window.clearTimeout(timeout);
+  }, [loadProfiles]);
+
+  useEffect(() => {
+    let cancelled = false;
+    void Promise.resolve().then(() => {
+      if (!selectedName) {
+        setSelectedDetail(null);
+        return;
+      }
+      setDetailLoading(true);
+      setDetailError(null);
+      api.getDashboardProfile(selectedName)
+        .then((detail) => {
+          if (!cancelled) setSelectedDetail(detail);
+        })
+        .catch((err: unknown) => {
+          if (!cancelled) setDetailError(String(err));
+        })
+        .finally(() => {
+          if (!cancelled) setDetailLoading(false);
+        });
+    });
+    return () => {
+      cancelled = true;
+    };
+  }, [selectedName]);
+
+  useLayoutEffect(() => {
+    setAfterTitle(
+      <span className="flex items-center gap-2">
+        {loading && <Spinner className="shrink-0 text-base text-primary" />}
+        <Badge tone="secondary" className="text-[10px]">
+          {profiles.length} profiles
+        </Badge>
+      </span>,
+    );
+    setEnd(
+      <Button
+        type="button"
+        size="sm"
+        outlined
+        onClick={loadProfiles}
+        disabled={loading}
+        prefix={loading ? <Spinner /> : <RefreshCw />}
+      >
+        {t.common.refresh}
+      </Button>,
+    );
+    return () => {
+      setAfterTitle(null);
+      setEnd(null);
+    };
+  }, [loadProfiles, loading, profiles.length, setAfterTitle, setEnd, t.common.refresh]);
+
+  const selectProfile = (name: string) => {
+    setSearchParams({ profile: name });
+  };
+
+  return (
+    <div className="flex flex-col gap-6" data-dashboard-profiles-page>
+      <PluginSlot name="profiles:top" />
+
+      <Card>
+        <CardHeader>
+          <div className="flex items-start justify-between gap-3">
+            <div>
+              <CardTitle>Profile control plane</CardTitle>
+              <CardDescription>
+                Read-only profile inventory from native Hermes profile metadata. No secrets, prompts, or log contents are exposed.
+              </CardDescription>
+            </div>
+            {activeProfile && (
+              <Badge tone="success" className="shrink-0 text-[10px]">
+                active: {activeProfile}
+              </Badge>
+            )}
+          </div>
+        </CardHeader>
+        <CardContent>
+          {error ? (
+            <p className="text-sm text-destructive">{error}</p>
+          ) : loading && profiles.length === 0 ? (
+            <div className="flex items-center justify-center py-16">
+              <Spinner className="text-2xl text-primary" />
+            </div>
+          ) : (
+            <div className="grid gap-3 md:grid-cols-2 xl:grid-cols-3">
+              {profiles.map((profile) => (
+                <ProfileCard
+                  key={profile.name}
+                  profile={profile}
+                  selected={profile.name === selectedName}
+                  onSelect={() => selectProfile(profile.name)}
+                />
+              ))}
+            </div>
+          )}
+        </CardContent>
+      </Card>
+
+      {selectedName && (
+        <ProfileDetailCard
+          detail={selectedDetail}
+          loading={detailLoading}
+          error={detailError}
+          selectedName={selectedName}
+        />
+      )}
+
+      <PluginSlot name="profiles:bottom" />
+    </div>
+  );
+}
+
+function ProfileCard({
+  profile,
+  selected,
+  onSelect,
+}: {
+  profile: DashboardProfileSummary;
+  selected: boolean;
+  onSelect: () => void;
+}) {
+  return (
+    <button
+      type="button"
+      onClick={onSelect}
+      data-profile-card={profile.name}
+      aria-pressed={selected}
+      className={cn(
+        "group border border-current/15 bg-background-base/35 p-4 text-left",
+        "transition-colors hover:border-current/35 hover:bg-background-base/55",
+        "focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-midground/50",
+        selected && "border-primary/70 bg-primary/10",
+      )}
+    >
+      <div className="flex items-start justify-between gap-3">
+        <div className="min-w-0">
+          <div className="flex items-center gap-2">
+            <h3 className="truncate font-expanded text-sm font-bold tracking-[0.08em] text-midground">
+              {profile.name}
+            </h3>
+            {profile.is_active && <CheckCircle2 className="h-3.5 w-3.5 shrink-0 text-success" />}
+          </div>
+          <p className="mt-1 truncate text-xs text-muted-foreground">
+            {profile.provider ?? "provider?"} / {profile.model ?? "model?"}
+          </p>
+        </div>
+        <Badge tone={profile.gateway_running ? "success" : "outline"} className="shrink-0 text-[10px]">
+          gateway {profile.gateway_running ? "on" : "off"}
+        </Badge>
+      </div>
+
+      <div className="mt-4 grid grid-cols-3 gap-2 text-[0.68rem] text-muted-foreground/75">
+        <Metric icon={Bot} label="skills" value={String(profile.skill_count)} />
+        <Metric icon={KeyRound} label="env" value={profile.has_env ? "yes" : "no"} />
+        <Metric icon={CircleDot} label="kind" value={profile.is_default ? "default" : "named"} />
+      </div>
+
+      <p className="mt-3 truncate text-[0.65rem] text-muted-foreground/45" title={profile.path}>
+        {profile.path}
+      </p>
+    </button>
+  );
+}
+
+function ProfileDetailCard({
+  detail,
+  loading,
+  error,
+  selectedName,
+}: {
+  detail: DashboardProfileDetail | null;
+  loading: boolean;
+  error: string | null;
+  selectedName: string;
+}) {
+  return (
+    <Card data-profile-detail={selectedName}>
+      <CardHeader>
+        <div className="flex items-start justify-between gap-3">
+          <div>
+            <CardTitle>{selectedName}</CardTitle>
+            <CardDescription>Profile paths, sessions, and log-file metadata.</CardDescription>
+          </div>
+          {loading && <Spinner className="text-primary" />}
+        </div>
+      </CardHeader>
+      <CardContent>
+        {error ? (
+          <p className="text-sm text-destructive">{error}</p>
+        ) : detail ? (
+          <div className="grid gap-4 xl:grid-cols-[minmax(0,1fr)_minmax(320px,0.7fr)]">
+            <div className="grid gap-3 md:grid-cols-2">
+              <InfoRow icon={Folder} label="Profile path" value={detail.path} />
+              <InfoRow icon={FileText} label="Config" value={detail.config_path} />
+              <InfoRow icon={KeyRound} label="Env file" value={detail.env_path} />
+              <InfoRow icon={Terminal} label="Alias" value={detail.alias_path ?? "none"} />
+            </div>
+
+            <div className="grid gap-3">
+              <div className="border border-current/10 p-3">
+                <div className="mb-2 flex items-center gap-2 text-xs text-muted-foreground">
+                  <MessageSquare className="h-3.5 w-3.5" /> Sessions
+                </div>
+                <div className="flex gap-3 text-sm">
+                  <Badge tone="secondary">{detail.sessions.total} total</Badge>
+                  <Badge tone={detail.sessions.active ? "success" : "outline"}>
+                    {detail.sessions.active} active
+                  </Badge>
+                </div>
+                {detail.sessions.recent.length > 0 && (
+                  <ul className="mt-3 space-y-2 text-xs text-muted-foreground">
+                    {detail.sessions.recent.slice(0, 3).map((session) => (
+                      <li key={session.session_id ?? session.id ?? "session"} className="truncate">
+                        {session.title || session.session_id || session.id || "Untitled session"}
+                      </li>
+                    ))}
+                  </ul>
+                )}
+              </div>
+
+              <div className="border border-current/10 p-3">
+                <div className="mb-2 flex items-center gap-2 text-xs text-muted-foreground">
+                  <FileText className="h-3.5 w-3.5" /> Logs
+                </div>
+                {detail.logs.length === 0 ? (
+                  <p className="text-xs text-muted-foreground">No log files found.</p>
+                ) : (
+                  <ul className="space-y-2 text-xs text-muted-foreground">
+                    {detail.logs.slice(0, 4).map((log) => (
+                      <li key={log.path} className="flex justify-between gap-3">
+                        <span className="truncate">{log.name}</span>
+                        <span className="shrink-0 tabular-nums">{formatBytes(log.size_bytes)}</span>
+                      </li>
+                    ))}
+                  </ul>
+                )}
+              </div>
+            </div>
+          </div>
+        ) : (
+          <div className="flex items-center justify-center py-10">
+            <Spinner className="text-xl text-primary" />
+          </div>
+        )}
+      </CardContent>
+    </Card>
+  );
+}
+
+function Metric({
+  icon: Icon,
+  label,
+  value,
+}: {
+  icon: ComponentType<{ className?: string }>;
+  label: string;
+  value: string;
+}) {
+  return (
+    <div className="min-w-0 border border-current/10 p-2">
+      <div className="mb-1 flex items-center gap-1.5 text-muted-foreground/55">
+        <Icon className="h-3 w-3 shrink-0" />
+        <span className="truncate">{label}</span>
+      </div>
+      <p className="truncate text-midground">{value}</p>
+    </div>
+  );
+}
+
+function InfoRow({
+  icon: Icon,
+  label,
+  value,
+}: {
+  icon: ComponentType<{ className?: string }>;
+  label: string;
+  value: string;
+}) {
+  return (
+    <div className="min-w-0 border border-current/10 p-3">
+      <div className="mb-1 flex items-center gap-2 text-xs text-muted-foreground">
+        <Icon className="h-3.5 w-3.5 shrink-0" />
+        {label}
+      </div>
+      <p className="truncate text-sm text-midground" title={value}>
+        {value}
+      </p>
+    </div>
+  );
+}
+
+function formatBytes(size: number): string {
+  if (size >= 1_048_576) return `${(size / 1_048_576).toFixed(1)} MB`;
+  if (size >= 1024) return `${(size / 1024).toFixed(1)} KB`;
+  return `${size} B`;
+}
