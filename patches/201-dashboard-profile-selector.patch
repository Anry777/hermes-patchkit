diff --git a/web/src/components/SidebarProfileSelector.tsx b/web/src/components/SidebarProfileSelector.tsx
new file mode 100644
index 000000000..4fdc89253
--- /dev/null
+++ b/web/src/components/SidebarProfileSelector.tsx
@@ -0,0 +1,111 @@
+import { useEffect, useMemo, useState } from "react";
+import { ChevronDown, Layers3 } from "lucide-react";
+import { useLocation, useNavigate } from "react-router-dom";
+import { Spinner } from "@nous-research/ui";
+
+import { api, type DashboardProfileSummary } from "@/lib/api";
+import { cn } from "@/lib/utils";
+
+export function SidebarProfileSelector() {
+  const [profiles, setProfiles] = useState<DashboardProfileSummary[]>([]);
+  const [activeProfile, setActiveProfile] = useState<string | null>(null);
+  const [loading, setLoading] = useState(true);
+  const [error, setError] = useState<string | null>(null);
+  const navigate = useNavigate();
+  const location = useLocation();
+
+  useEffect(() => {
+    let cancelled = false;
+    void Promise.resolve().then(() => {
+      setLoading(true);
+      setError(null);
+      api
+        .getDashboardProfiles()
+        .then((resp) => {
+          if (cancelled) return;
+          setProfiles(resp.profiles);
+          setActiveProfile(resp.active_profile);
+        })
+        .catch((err: unknown) => {
+          if (cancelled) return;
+          setError(String(err));
+        })
+        .finally(() => {
+          if (!cancelled) setLoading(false);
+        });
+    });
+    return () => {
+      cancelled = true;
+    };
+  }, []);
+
+  const selectedName = useMemo(() => {
+    const fromQuery = new URLSearchParams(location.search).get("profile");
+    if (fromQuery && profiles.some((p) => p.name === fromQuery)) return fromQuery;
+    return activeProfile ?? profiles.find((p) => p.is_active)?.name ?? profiles[0]?.name ?? "";
+  }, [activeProfile, location.search, profiles]);
+
+  const selected = profiles.find((p) => p.name === selectedName) ?? null;
+
+  const handleSelect = (name: string) => {
+    const params = new URLSearchParams(location.search);
+    params.set("profile", name);
+    navigate({ pathname: "/profiles", search: `?${params.toString()}` });
+  };
+
+  return (
+    <div className="border-b border-current/10 px-4 py-3" data-dashboard-profile-selector>
+      <div className="mb-2 flex items-center justify-between gap-2">
+        <div className="flex min-w-0 items-center gap-2 text-muted-foreground/55">
+          <Layers3 className="h-3.5 w-3.5 shrink-0" />
+          <span className="font-mondwest text-[0.6rem] tracking-[0.15em]">
+            Profile
+          </span>
+        </div>
+        {loading && <Spinner className="text-[0.7rem] text-muted-foreground/60" />}
+      </div>
+
+      {error ? (
+        <p className="line-clamp-2 text-[0.65rem] leading-snug text-destructive/80">
+          Profile inventory unavailable
+        </p>
+      ) : (
+        <div className="relative">
+          <select
+            aria-label="Dashboard profile selector"
+            value={selectedName}
+            disabled={loading || profiles.length === 0}
+            onChange={(event) => handleSelect(event.target.value)}
+            className={cn(
+              "w-full appearance-none rounded-none border border-current/15",
+              "bg-background-base/40 py-2 pl-3 pr-8",
+              "font-mondwest text-[0.72rem] tracking-[0.08em] text-midground",
+              "outline-none transition-colors",
+              "hover:border-current/30 focus:border-current/50",
+              "disabled:cursor-not-allowed disabled:opacity-50",
+            )}
+          >
+            {profiles.map((profile) => (
+              <option key={profile.name} value={profile.name}>
+                {profile.name}
+              </option>
+            ))}
+          </select>
+          <ChevronDown className="pointer-events-none absolute right-2.5 top-1/2 h-3.5 w-3.5 -translate-y-1/2 text-muted-foreground/60" />
+        </div>
+      )}
+
+      {selected && (
+        <div className="mt-2 flex flex-wrap items-center gap-x-2 gap-y-1 text-[0.62rem] leading-snug text-muted-foreground/60">
+          {selected.is_active && <span className="text-success">active</span>}
+          {selected.is_default && <span>default</span>}
+          <span>{selected.provider ?? "provider?"}</span>
+          <span>{selected.model ?? "model?"}</span>
+          <span className={selected.gateway_running ? "text-success" : undefined}>
+            gateway {selected.gateway_running ? "on" : "off"}
+          </span>
+        </div>
+      )}
+    </div>
+  );
+}
