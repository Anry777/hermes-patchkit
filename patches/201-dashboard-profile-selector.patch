+    model: string | null;
+    title: string | null;
+    started_at: number | null;
+    ended_at: number | null;
+    end_reason: string | null;
+    last_active: number | null;
+    message_count: number | null;
+    tool_call_count: number | null;
+  }>;
+}
+
+export interface DashboardProfileLogSummary {
+  name: string;
+  path: string;
+  size_bytes: number;
+  modified_at: number;
+}
+
+export interface DashboardProfileDetail extends DashboardProfileSummary {
+  config_path: string;
+  env_path: string;
+  sessions: DashboardProfileSessionSummary;
+  logs: DashboardProfileLogSummary[];
+}
+
+export interface DashboardProfilesResponse {
+  active_profile: string;
+  total: number;
+  profiles: DashboardProfileSummary[];
+}
+
 export interface SessionInfo {
