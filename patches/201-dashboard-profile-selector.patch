@@ -0,0 +1,50 @@
+"""Source contract tests for the dashboard profile selector frontend slice.
+
+The project does not currently ship a JS unit-test runner for the web app, so
+these tests guard the integration points that make the profile inventory API
+visible in the dashboard shell. They complement `npm run build` and live browser
+smoke checks.
+"""
+
+from pathlib import Path
+
+ROOT = Path(__file__).resolve().parents[2]
+WEB_SRC = ROOT / "web" / "src"
+
+
+def _read(relative: str) -> str:
+    return (WEB_SRC / relative).read_text(encoding="utf-8")
+
+
+def test_dashboard_has_profiles_route_and_nav_item():
+    app = _read("App.tsx")
+
+    assert 'import ProfilesPage from "@/pages/ProfilesPage";' in app
+    assert '"/profiles": ProfilesPage' in app
+    assert 'path: "/profiles"' in app
+    assert 'labelKey: "profiles"' in app
+
+
+def test_dashboard_sidebar_renders_profile_selector():
+    app = _read("App.tsx")
+
+    assert 'import { SidebarProfileSelector } from "@/components/SidebarProfileSelector";' in app
+    assert "<SidebarProfileSelector" in app
+
+
+def test_dashboard_api_client_exposes_profile_inventory():
+    api = _read("lib/api.ts")
+
+    assert "DashboardProfilesResponse" in api
+    assert "DashboardProfileSummary" in api
+    assert "getDashboardProfiles:" in api
+    assert '"/api/dashboard/profiles"' in api
+
+
+def test_profiles_page_uses_profile_inventory_api():
+    page = _read("pages/ProfilesPage.tsx")
+
+    assert "api.getDashboardProfiles" in page
+    assert "api.getDashboardProfile" in page
+    assert "active_profile" in page
+    assert "gateway_running" in page
