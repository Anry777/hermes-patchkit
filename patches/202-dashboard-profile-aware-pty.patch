diff --git a/hermes_cli/web_server.py b/hermes_cli/web_server.py
index 2e542a16b..9db632fe4 100644
--- a/hermes_cli/web_server.py
+++ b/hermes_cli/web_server.py
@@ -2798,6 +2798,7 @@ _event_lock = asyncio.Lock()
 def _resolve_chat_argv(
     resume: Optional[str] = None,
     sidecar_url: Optional[str] = None,
+    profile: Optional[str] = None,
 ) -> tuple[list[str], Optional[str], Optional[dict]]:
     """Resolve the argv + cwd + env for the chat PTY.
 
@@ -2813,6 +2814,11 @@ def _resolve_chat_argv(
     `sidecar_url` (when set) is forwarded as ``HERMES_TUI_SIDECAR_URL`` so
     the spawned ``tui_gateway.entry`` can mirror dispatcher emits to the
     dashboard's ``/api/pub`` endpoint (see :func:`pub_ws`).
+
+    `profile` selects a Hermes profile for this PTY child only.  The dashboard
+    server process keeps its own HERMES_HOME; only the spawned TUI receives the
+    profile-scoped environment, so opening a profile terminal does not mutate
+    the sticky active profile or leak profile state across tabs.
     """
     from hermes_cli.main import PROJECT_ROOT, _make_tui_argv
 
@@ -2820,6 +2826,12 @@ def _resolve_chat_argv(
     env = os.environ.copy()
     env.setdefault("NODE_ENV", "production")
 
+    if profile:
+        from hermes_cli.profiles import resolve_profile_env
+
+        env["HERMES_HOME"] = resolve_profile_env(profile)
+        env["HERMES_DASHBOARD_PROFILE"] = profile
+
     if resume:
         env["HERMES_TUI_RESUME"] = resume
 
@@ -2829,6 +2841,30 @@ def _resolve_chat_argv(
     return list(argv), str(cwd) if cwd else None, env
 
 
+def _dashboard_pty_profile_or_close_code(profile: Optional[str]) -> tuple[Optional[str], Optional[int]]:
+    """Validate an optional /api/pty profile query parameter.
+
+    Returns ``(profile, None)`` when the query is absent or valid.  Returns
+    ``(None, close_code)`` when the WebSocket should be rejected before accept.
+    """
+    if not profile:
+        return None, None
+
+    try:
+        from hermes_cli.profiles import profile_exists, validate_profile_name
+
+        validate_profile_name(profile)
+        if not profile_exists(profile):
+            return None, 4404
+    except ValueError:
+        return None, 4400
+    except Exception:
+        _log.exception("Failed to validate dashboard PTY profile %r", profile)
+        return None, 1011
+
+    return profile, None
+
+
 def _build_sidecar_url(channel: str) -> Optional[str]:
     """ws:// URL the PTY child should publish events to, or None when unbound."""
     host = getattr(app.state, "bound_host", None)
@@ -2882,6 +2918,13 @@ async def pty_ws(ws: WebSocket) -> None:
         await ws.close(code=4403)
         return
 
+    profile, profile_close_code = _dashboard_pty_profile_or_close_code(
+        ws.query_params.get("profile") or None
+    )
+    if profile_close_code is not None:
+        await ws.close(code=profile_close_code)
+        return
+
     await ws.accept()
 
     # --- spawn PTY ------------------------------------------------------
@@ -2890,7 +2933,12 @@ async def pty_ws(ws: WebSocket) -> None:
     sidecar_url = _build_sidecar_url(channel) if channel else None
 
     try:
-        argv, cwd, env = _resolve_chat_argv(resume=resume, sidecar_url=sidecar_url)
+        if profile:
+            argv, cwd, env = _resolve_chat_argv(
+                resume=resume, sidecar_url=sidecar_url, profile=profile
+            )
+        else:
+            argv, cwd, env = _resolve_chat_argv(resume=resume, sidecar_url=sidecar_url)
     except SystemExit as exc:
         # _make_tui_argv calls sys.exit(1) when node/npm is missing.
         await ws.send_text(f"\r\n\x1b[31mChat unavailable: {exc}\x1b[0m\r\n")
