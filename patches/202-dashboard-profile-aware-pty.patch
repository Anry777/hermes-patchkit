+    assert "profile: string | null" in page
+    assert 'if (profile) qs.set("profile", profile);' in page
+    assert 'const profileRef = useRef<string | null>(searchParams.get("profile"));' in page
+    assert "buildWsUrl(token, resumeRef.current, channel, profileRef.current)" in page
diff --git a/tests/hermes_cli/test_web_server.py b/tests/hermes_cli/test_web_server.py
index 0093dfb97..eea972645 100644
--- a/tests/hermes_cli/test_web_server.py
+++ b/tests/hermes_cli/test_web_server.py
@@ -1954,6 +1954,80 @@ class TestPtyWebSocket:
         assert "channel=abc-123" in url
         assert "token=" in url
 
+    def test_profile_query_is_validated_and_forwarded_to_pty_resolver(self, monkeypatch):
+        root = Path(os.environ["HERMES_HOME"])
+        profile_dir = root / "profiles" / "coder"
+        profile_dir.mkdir(parents=True)
+        (profile_dir / "config.yaml").write_text("model: coder-model\n", encoding="utf-8")
+        captured: dict = {}
+
+        def fake_resolve(resume=None, sidecar_url=None, profile=None):
+            captured["profile"] = profile
+            return (["/bin/sh", "-c", "printf profile-ok"], None, None)
+
+        monkeypatch.setattr(self.ws_module, "_resolve_chat_argv", fake_resolve)
+
+        with self.client.websocket_connect(self._url(profile="coder")) as conn:
+            try:
+                conn.receive_bytes()
+            except Exception:
+                pass
+
+        assert captured.get("profile") == "coder"
+
+    def test_profile_query_rejects_invalid_or_missing_profile(self, monkeypatch):
+        from starlette.websockets import WebSocketDisconnect
+
+        called = False
+
+        def fake_resolve(*args, **kwargs):
+            nonlocal called
+            called = True
+            return (["/bin/cat"], None, None)
+
+        monkeypatch.setattr(self.ws_module, "_resolve_chat_argv", fake_resolve)
+
+        with pytest.raises(WebSocketDisconnect) as invalid_exc:
+            with self.client.websocket_connect(self._url(profile="../bad")):
+                pass
+        assert invalid_exc.value.code == 4400
+
+        with pytest.raises(WebSocketDisconnect) as missing_exc:
+            with self.client.websocket_connect(self._url(profile="missing")):
+                pass
+        assert missing_exc.value.code == 4404
+        assert called is False
+
+    def test_resolve_chat_argv_sets_profile_scoped_env_without_global_switch(self, monkeypatch):
+        import hermes_cli.main as main_mod
+        import hermes_cli.web_server as ws_mod
+
+        root = Path(os.environ["HERMES_HOME"])
+        profile_dir = root / "profiles" / "coder"
+        profile_dir.mkdir(parents=True)
+        (profile_dir / "config.yaml").write_text("model: coder-model\n", encoding="utf-8")
+        (root / "active_profile").write_text("default\n", encoding="utf-8")
+
+        monkeypatch.setattr(
+            main_mod,
+            "_make_tui_argv",
+            lambda tui_dir, tui_dev: (["/bin/true"], root / "ui-tui"),
+        )
+
+        argv, cwd, env = ws_mod._resolve_chat_argv(
+            resume="sess-42",
+            sidecar_url="ws://127.0.0.1:9119/api/pub?token=t&channel=c",
+            profile="coder",
+        )
+
+        assert argv == ["/bin/true"]
+        assert cwd == str(root / "ui-tui")
+        assert env["HERMES_HOME"] == str(profile_dir)
+        assert env["HERMES_DASHBOARD_PROFILE"] == "coder"
+        assert env["HERMES_TUI_RESUME"] == "sess-42"
+        assert env["HERMES_TUI_SIDECAR_URL"].startswith("ws://127.0.0.1:9119/api/pub?")
+        assert (root / "active_profile").read_text(encoding="utf-8").strip() == "default"
+
     def test_pub_broadcasts_to_events_subscribers(self, monkeypatch):
         """Frame written to /api/pub is rebroadcast verbatim to every
         /api/events subscriber on the same channel."""
