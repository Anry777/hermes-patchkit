From: Anry777 <Anry777@users.noreply.github.com>
Date: Sun, 3 May 2026 16:57:24 +0300
Subject: [PATCH] fix: allow remote dashboard PTY when public

---
 hermes_cli/web_server.py            | 25 ++++++++++--
 tests/hermes_cli/test_web_server.py | 61 +++++++++++++++++++++++++++++
 2 files changed, 82 insertions(+), 4 deletions(-)

diff --git a/hermes_cli/web_server.py b/hermes_cli/web_server.py
index 9db632fe4..a4c1f797c 100644
--- a/hermes_cli/web_server.py
+++ b/hermes_cli/web_server.py
@@ -2795,6 +2795,22 @@ _event_channels: dict[str, set] = {}
 _event_lock = asyncio.Lock()
 
 
+def _dashboard_ws_client_allowed(client_host: str) -> bool:
+    """Return whether a dashboard WebSocket peer may connect.
+
+    Embedded chat/PTY endpoints are loopback-only by default. When the
+    dashboard was explicitly started with ``--insecure`` for a non-loopback
+    bind, HTTP already exposes the dashboard to that trusted network; allow the
+    authenticated WebSocket endpoints too so the in-browser terminal works from
+    the same remote browser.
+    """
+    if not client_host:
+        return True
+    if client_host in _LOOPBACK_HOSTS:
+        return True
+    return bool(getattr(app.state, "allow_public", False))
+
+
 def _resolve_chat_argv(
     resume: Optional[str] = None,
     sidecar_url: Optional[str] = None,
@@ -2914,7 +2930,7 @@ async def pty_ws(ws: WebSocket) -> None:
         return
 
     client_host = ws.client.host if ws.client else ""
-    if client_host and client_host not in _LOOPBACK_HOSTS:
+    if not _dashboard_ws_client_allowed(client_host):
         await ws.close(code=4403)
         return
 
@@ -3034,7 +3050,7 @@ async def gateway_ws(ws: WebSocket) -> None:
         return
 
     client_host = ws.client.host if ws.client else ""
-    if client_host and client_host not in _LOOPBACK_HOSTS:
+    if not _dashboard_ws_client_allowed(client_host):
         await ws.close(code=4403)
         return
 
@@ -3067,7 +3083,7 @@ async def pub_ws(ws: WebSocket) -> None:
         return
 
     client_host = ws.client.host if ws.client else ""
-    if client_host and client_host not in _LOOPBACK_HOSTS:
+    if not _dashboard_ws_client_allowed(client_host):
         await ws.close(code=4403)
         return
 
@@ -3097,7 +3113,7 @@ async def events_ws(ws: WebSocket) -> None:
         return
 
     client_host = ws.client.host if ws.client else ""
-    if client_host and client_host not in _LOOPBACK_HOSTS:
+    if not _dashboard_ws_client_allowed(client_host):
         await ws.close(code=4403)
         return
 
@@ -3707,6 +3723,7 @@ def start_server(
     # PTY child uses to publish events to the dashboard sidebar.
     app.state.bound_host = host
     app.state.bound_port = port
+    app.state.allow_public = allow_public
 
     if open_browser:
         import webbrowser
diff --git a/tests/hermes_cli/test_web_server.py b/tests/hermes_cli/test_web_server.py
index eea972645..164e09392 100644
--- a/tests/hermes_cli/test_web_server.py
