@@ -1753,6 +1753,7 @@ class TestPtyWebSocket:
         # its own fake argv via ``ws._resolve_chat_argv``.
         self.ws_module = ws
         monkeypatch.setattr(ws, "_DASHBOARD_EMBEDDED_CHAT_ENABLED", True)
+        monkeypatch.setattr(ws.app.state, "allow_public", False, raising=False)
         self.token = ws._SESSION_TOKEN
         self.client = TestClient(ws.app)
 
@@ -1800,6 +1801,66 @@ class TestPtyWebSocket:
                 pass
         assert exc.value.code == 4401
 
+    def test_remote_pty_client_allowed_when_public_dashboard(self, monkeypatch):
+        from starlette.testclient import TestClient
+
+        monkeypatch.setattr(
+            self.ws_module,
+            "_resolve_chat_argv",
+            lambda resume=None, sidecar_url=None: (
+                ["/bin/sh", "-c", "printf remote-pty-ok"],
+                None,
+                None,
+            ),
+        )
+        monkeypatch.setattr(
+            self.ws_module.app.state, "allow_public", True, raising=False
+        )
+        remote_client = TestClient(
+            self.ws_module.app,
+            base_url="http://10.50.50.28:9119",
+            client=("10.50.50.99", 50123),
+        )
+
+        with remote_client.websocket_connect(self._url(channel="remote-pty")) as conn:
+            buf = b""
+            import time
+
+            deadline = time.monotonic() + 5.0
+            while time.monotonic() < deadline:
+                try:
+                    frame = conn.receive_bytes()
+                except Exception:
+                    break
+                if frame:
+                    buf += frame
+                if b"remote-pty-ok" in buf:
+                    break
+        assert b"remote-pty-ok" in buf
+
+    def test_remote_pty_client_rejected_without_public_dashboard(self, monkeypatch):
+        from starlette.testclient import TestClient
+        from starlette.websockets import WebSocketDisconnect
+
+        monkeypatch.setattr(
+            self.ws_module,
+            "_resolve_chat_argv",
+            lambda resume=None, sidecar_url=None: (["/bin/cat"], None, None),
+        )
+        monkeypatch.setattr(
+            self.ws_module.app.state, "allow_public", False, raising=False
+        )
+        remote_client = TestClient(
+            self.ws_module.app,
+            base_url="http://10.50.50.28:9119",
+            client=("10.50.50.99", 50123),
+        )
+
+        with pytest.raises(WebSocketDisconnect) as exc:
+            with remote_client.websocket_connect(self._url(channel="remote-pty")):
+                pass
+        assert exc.value.code == 4403
+
