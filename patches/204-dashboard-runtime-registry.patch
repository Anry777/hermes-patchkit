 _event_lock = asyncio.Lock()
+_PTY_SESSIONS: Dict[str, Dict[str, Any]] = {}
+_PTY_SESSIONS_LOCK = threading.Lock()
 
 
 def _dashboard_ws_client_allowed(client_host: str) -> bool:
@@ -2916,6 +2991,53 @@ def _channel_or_close_code(ws: WebSocket) -> Optional[str]:
     return channel if _VALID_CHANNEL_RE.match(channel) else None
 
 
+def _register_pty_session(
+    *,
+    channel: Optional[str],
+    bridge: PtyBridge,
+    profile: Optional[str],
+    resume: Optional[str],
+    cwd: Optional[str],
+    client_host: str,
+    cols: int = 80,
+    rows: int = 24,
+) -> str:
+    session_id = channel or f"pty-{bridge.pid}"
+    now = time.time()
+    with _PTY_SESSIONS_LOCK:
+        _PTY_SESSIONS[session_id] = {
+            "id": session_id,
+            "channel": channel,
+            "pid": bridge.pid,
+            "profile": profile or "default",
+            "resume": resume,
+            "cwd": cwd,
+            "client_host": client_host or None,
+            "started_at": now,
+            "last_activity": now,
+            "cols": cols,
+            "rows": rows,
+        }
+    return session_id
+
+
+def _touch_pty_session(session_id: str, *, cols: Optional[int] = None, rows: Optional[int] = None) -> None:
+    with _PTY_SESSIONS_LOCK:
+        record = _PTY_SESSIONS.get(session_id)
+        if not record:
+            return
+        record["last_activity"] = time.time()
+        if cols is not None:
+            record["cols"] = cols
+        if rows is not None:
+            record["rows"] = rows
+
+
+def _unregister_pty_session(session_id: str) -> None:
+    with _PTY_SESSIONS_LOCK:
+        _PTY_SESSIONS.pop(session_id, None)
+
+
 @app.websocket("/api/pty")
