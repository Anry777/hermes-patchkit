+def _serialize_dashboard_runtime_registry() -> Dict[str, Any]:
+    """Return safe, read-only runtime/process metadata for the dashboard.
+
+    This intentionally exposes only process/session metadata. It does not include
+    argv, environment variables, terminal output, session messages, log contents,
+    or memory bodies.
+    """
+    with _PTY_SESSIONS_LOCK:
+        pty_sessions = [
+            {
+                "id": str(record.get("id") or key),
+                "channel": record.get("channel"),
+                "pid": record.get("pid"),
+                "profile": record.get("profile") or "default",
+                "resume": record.get("resume"),
+                "cwd": record.get("cwd"),
+                "client_host": record.get("client_host"),
+                "started_at": record.get("started_at"),
+                "last_activity": record.get("last_activity"),
+                "cols": record.get("cols"),
+                "rows": record.get("rows"),
+            }
+            for key, record in sorted(_PTY_SESSIONS.items())
+        ]
+
+    actions: List[Dict[str, Any]] = []
+    for name, proc in sorted(_ACTION_PROCS.items()):
+        returncode = proc.poll()
+        actions.append({
+            "id": name,
+            "pid": proc.pid,
+            "alive": returncode is None,
+            "returncode": returncode,
+        })
+
+    event_channels = [
+        {"channel": channel, "subscribers": len(subscribers)}
+        for channel, subscribers in sorted(_event_channels.items())
+    ]
+
+    return {
+        "dashboard": {
+            "pid": os.getpid(),
+            "cwd": str(PROJECT_ROOT),
+            "hermes_home": str(get_hermes_home()),
+            "bound_host": getattr(app.state, "bound_host", None),
+            "bound_port": getattr(app.state, "bound_port", None),
+            "allow_public": bool(getattr(app.state, "allow_public", False)),
+            "embedded_chat_enabled": bool(_DASHBOARD_EMBEDDED_CHAT_ENABLED),
+            "started_at": _SERVER_STARTED_AT,
+        },
+        "pty_sessions": pty_sessions,
+        "actions": actions,
+        "event_channels": event_channels,
+        "counts": {
+            "pty_sessions": len(pty_sessions),
+            "actions": len(actions),
+            "event_channels": len(event_channels),
+        },
+    }
+
+
+@app.get("/api/dashboard/runtimes")
+async def get_dashboard_runtimes():
+    """Return read-only live runtime metadata for the dashboard control plane."""
+    try:
+        return _serialize_dashboard_runtime_registry()
+    except Exception:
+        _log.exception("GET /api/dashboard/runtimes failed")
+        raise HTTPException(status_code=500, detail="Internal server error")
+
+
 @app.get("/api/dashboard/profiles")
 async def get_dashboard_profiles():
     """Return read-only profile inventory for the dashboard control plane."""
