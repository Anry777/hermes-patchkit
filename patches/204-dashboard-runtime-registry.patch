     loop = asyncio.get_running_loop()
+    pty_session_id = _register_pty_session(
+        channel=channel,
+        bridge=bridge,
+        profile=profile,
+        resume=resume,
+        cwd=cwd,
+        client_host=client_host,
+    )
 
     # --- reader task: PTY master → WebSocket ----------------------------
     async def pump_pty_to_ws() -> None:
@@ -2988,6 +3118,7 @@ async def pty_ws(ws: WebSocket) -> None:
                 continue
             try:
                 await ws.send_bytes(chunk)
+                _touch_pty_session(pty_session_id)
             except Exception:
                 return
 
@@ -3013,9 +3144,11 @@ async def pty_ws(ws: WebSocket) -> None:
                 cols = int(match.group(1))
                 rows = int(match.group(2))
                 bridge.resize(cols=cols, rows=rows)
+                _touch_pty_session(pty_session_id, cols=cols, rows=rows)
                 continue
 
             bridge.write(raw)
