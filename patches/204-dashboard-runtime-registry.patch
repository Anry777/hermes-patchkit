@@ -0,0 +1,116 @@
+"""Tests for dashboard runtime registry API endpoints."""
+
+from __future__ import annotations
+
+import os
+import time
+
+import pytest
+
+
+def _client_with_dashboard_token(base_url: str = "http://testserver"):
+    try:
+        from starlette.testclient import TestClient
+    except ImportError:
+        pytest.skip("fastapi/starlette not installed")
+
+    from hermes_cli.web_server import app, _SESSION_HEADER_NAME, _SESSION_TOKEN
+
+    client = TestClient(app, base_url=base_url)
+    client.headers[_SESSION_HEADER_NAME] = _SESSION_TOKEN
+    return client
+
+
+class TestDashboardRuntimeRegistryApi:
+    def test_runtime_registry_requires_dashboard_session_token(self):
+        try:
+            from starlette.testclient import TestClient
+        except ImportError:
+            pytest.skip("fastapi/starlette not installed")
+
+        from hermes_cli.web_server import app
+
+        response = TestClient(app).get("/api/dashboard/runtimes")
+
+        assert response.status_code == 401
+
+    def test_runtime_registry_returns_dashboard_and_active_pty_sessions(self, monkeypatch):
+        from hermes_cli import web_server as ws
+
+        monkeypatch.setattr(ws, "_DASHBOARD_EMBEDDED_CHAT_ENABLED", True)
+        monkeypatch.setattr(ws.app.state, "bound_host", "10.50.50.28", raising=False)
+        monkeypatch.setattr(ws.app.state, "bound_port", 9119, raising=False)
+        monkeypatch.setattr(ws.app.state, "allow_public", True, raising=False)
+
+        started_at = time.time() - 5
+        with ws._PTY_SESSIONS_LOCK:
+            ws._PTY_SESSIONS.clear()
+            ws._PTY_SESSIONS["terminal-1"] = {
+                "id": "terminal-1",
+                "channel": "terminal-1",
+                "pid": 12345,
+                "profile": "hermesfix",
+                "resume": "session-123",
+                "cwd": "/tmp/project",
+                "client_host": "10.50.50.40",
+                "started_at": started_at,
+                "last_activity": started_at + 1,
+                "cols": 120,
+                "rows": 40,
+                "secret_env": "OPENAI_API_KEY=super-secret",
+            }
+
+        try:
+            response = _client_with_dashboard_token(
+                base_url="http://10.50.50.28:9119"
+            ).get("/api/dashboard/runtimes")
+        finally:
+            with ws._PTY_SESSIONS_LOCK:
+                ws._PTY_SESSIONS.clear()
+
+        assert response.status_code == 200
+        payload = response.json()
+        assert payload["dashboard"]["pid"] == os.getpid()
+        assert payload["dashboard"]["bound_host"] == "10.50.50.28"
+        assert payload["dashboard"]["bound_port"] == 9119
+        assert payload["dashboard"]["embedded_chat_enabled"] is True
+        assert payload["dashboard"]["allow_public"] is True
+        assert payload["counts"]["pty_sessions"] == 1
+
+        session = payload["pty_sessions"][0]
+        assert session == {
+            "id": "terminal-1",
+            "channel": "terminal-1",
+            "pid": 12345,
+            "profile": "hermesfix",
+            "resume": "session-123",
+            "cwd": "/tmp/project",
+            "client_host": "10.50.50.40",
+            "started_at": started_at,
+            "last_activity": started_at + 1,
+            "cols": 120,
+            "rows": 40,
+        }
+        assert "super-secret" not in str(payload)
+        assert "OPENAI_API_KEY" not in str(payload)
+
+    def test_runtime_registry_includes_event_channels_without_messages(self):
+        from hermes_cli import web_server as ws
+
+        class _FakeSubscriber:
+            pass
+
+        with ws._PTY_SESSIONS_LOCK:
+            ws._PTY_SESSIONS.clear()
+        ws._event_channels.clear()
+        ws._event_channels["events-1"] = {_FakeSubscriber(), _FakeSubscriber()}
+
+        try:
+            response = _client_with_dashboard_token().get("/api/dashboard/runtimes")
+        finally:
+            ws._event_channels.clear()
+
+        assert response.status_code == 200
+        payload = response.json()
+        assert payload["counts"]["event_channels"] == 1
+        assert payload["event_channels"] == [{"channel": "events-1", "subscribers": 2}]
