     except WebSocketDisconnect:
         pass
     finally:
@@ -3025,6 +3158,7 @@ async def pty_ws(ws: WebSocket) -> None:
         except (asyncio.CancelledError, Exception):
             pass
         bridge.close()
+        _unregister_pty_session(pty_session_id)
 
 
