+"""Tests for dashboard worker roster API endpoints."""
+
+from __future__ import annotations
+
+import json
+import os
+import time
+from pathlib import Path
+
+import pytest
+
+
+def _client_with_dashboard_token():
+    try:
+        from starlette.testclient import TestClient
+    except ImportError:
+        pytest.skip("fastapi/starlette not installed")
+
+    from hermes_cli.web_server import app, _SESSION_HEADER_NAME, _SESSION_TOKEN
+
+    client = TestClient(app)
+    client.headers[_SESSION_HEADER_NAME] = _SESSION_TOKEN
+    return client
+
+
+def _make_profile(root: Path, name: str) -> Path:
+    profile_dir = root / "profiles" / name
+    (profile_dir / "dashboard").mkdir(parents=True, exist_ok=True)
+    (profile_dir / "config.yaml").write_text("model: worker-model\n", encoding="utf-8")
+    return profile_dir
+
+
+class TestDashboardWorkerRosterApi:
+    def test_worker_roster_requires_dashboard_session_token(self):
+        try:
+            from starlette.testclient import TestClient
+        except ImportError:
+            pytest.skip("fastapi/starlette not installed")
+
+        from hermes_cli.web_server import app
+
+        response = TestClient(app).get("/api/dashboard/worker-roster")
+
+        assert response.status_code == 401
+
+    def test_worker_roster_returns_configured_and_runtime_workers(self):
+        from hermes_cli import web_server as ws
+
+        root = Path(os.environ["HERMES_HOME"])
+        profile_dir = _make_profile(root, "coder")
+        (profile_dir / "dashboard" / "worker_roster.json").write_text(
+            json.dumps({
+                "workers": [
+                    {
+                        "id": "reviewer",
+                        "role": "code reviewer",
+                        "lane": "quality",
+                        "mission": "Review dashboard patches",
+                        "preferred_model": "gpt-5.4",
+                        "capabilities": ["review", "tests"],
+                        "cwd": "/repo",
+                        "secret": "OPENAI_API_KEY=super-secret",
+                    }
+                ]
+            }),
+            encoding="utf-8",
+        )
+
+        now = time.time()
+        with ws._PTY_SESSIONS_LOCK:
+            ws._PTY_SESSIONS.clear()
+            ws._PTY_SESSIONS["terminal-1"] = {
+                "id": "terminal-1",
+                "channel": "terminal-1",
+                "pid": 2222,
+                "profile": "coder",
+                "resume": "session-1",
+                "cwd": "/repo",
+                "client_host": "127.0.0.1",
+                "started_at": now,
+                "last_activity": now,
+                "cols": 100,
+                "rows": 30,
+            }
+
+        try:
+            response = _client_with_dashboard_token().get("/api/dashboard/worker-roster")
+        finally:
+            with ws._PTY_SESSIONS_LOCK:
+                ws._PTY_SESSIONS.clear()
+
+        assert response.status_code == 200
+        payload = response.json()
+        assert payload["counts"]["configured_workers"] == 1
+        assert payload["counts"]["runtime_workers"] == 1
+        assert payload["counts"]["workers"] == 2
+
+        workers = {item["id"]: item for item in payload["workers"]}
+        assert workers["coder:reviewer"] == {
+            "id": "coder:reviewer",
+            "source": "roster",
+            "profile": "coder",
+            "state": "configured",
+            "role": "code reviewer",
+            "lane": "quality",
+            "mission": "Review dashboard patches",
+            "preferred_model": "gpt-5.4",
+            "capabilities": ["review", "tests"],
+            "cwd": "/repo",
+            "terminal_id": None,
+            "pid": None,
+            "resume": None,
+            "last_activity": None,
+        }
+        assert workers["pty:terminal-1"]["source"] == "runtime"
+        assert workers["pty:terminal-1"]["profile"] == "coder"
+        assert workers["pty:terminal-1"]["state"] == "running"
+        assert workers["pty:terminal-1"]["pid"] == 2222
+        assert workers["pty:terminal-1"]["terminal_id"] == "terminal-1"
+        assert "super-secret" not in str(payload)
+        assert "OPENAI_API_KEY" not in str(payload)
+
+    def test_worker_roster_reports_bad_profile_roster_without_breaking_summary(self):
+        root = Path(os.environ["HERMES_HOME"])
+        profile_dir = _make_profile(root, "broken")
+        (profile_dir / "dashboard" / "worker_roster.json").write_text("{bad json", encoding="utf-8")
+
+        response = _client_with_dashboard_token().get("/api/dashboard/worker-roster")
+
+        assert response.status_code == 200
+        payload = response.json()
+        assert payload["workers"] == []
+        assert payload["errors"] == [{"profile": "broken", "error": "invalid worker_roster.json"}]
