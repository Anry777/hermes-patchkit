+def _safe_worker_roster_value(value: Any) -> Optional[Any]:
+    """Return a JSON-safe scalar/list roster value without nested secret bags."""
+    if value is None:
+        return None
+    if isinstance(value, (str, int, float, bool)):
+        return value
+    if isinstance(value, list):
+        safe_items = [item for item in value if isinstance(item, (str, int, float, bool))]
+        return safe_items
+    return None
+
+
+def _configured_worker_from_roster(profile: str, index: int, item: Dict[str, Any]) -> Dict[str, Any]:
+    raw_id = item.get("id") or item.get("name") or f"worker-{index + 1}"
+    worker_id = str(raw_id).strip() or f"worker-{index + 1}"
+    worker = {
+        "id": f"{profile}:{worker_id}",
+        "source": "roster",
+        "profile": profile,
+        "state": "configured",
+        "role": None,
+        "lane": None,
+        "mission": None,
+        "preferred_model": None,
+        "capabilities": [],
+        "cwd": None,
+        "terminal_id": None,
+        "pid": None,
+        "resume": None,
+        "last_activity": None,
+    }
+    for key in ("role", "lane", "mission", "preferred_model", "capabilities", "cwd"):
+        safe_value = _safe_worker_roster_value(item.get(key))
+        if safe_value is not None:
+            worker[key] = safe_value
+    if not isinstance(worker["capabilities"], list):
+        worker["capabilities"] = []
+    return worker
+
+
+def _load_profile_worker_roster(profile: str, profile_dir: Path) -> Tuple[List[Dict[str, Any]], Optional[Dict[str, str]]]:
+    roster_path = profile_dir / "dashboard" / "worker_roster.json"
+    if not roster_path.exists():
+        return [], None
+    try:
+        raw = json.loads(roster_path.read_text(encoding="utf-8"))
+    except Exception:
+        return [], {"profile": profile, "error": "invalid worker_roster.json"}
+
+    workers_raw = raw.get("workers") if isinstance(raw, dict) else raw
+    if not isinstance(workers_raw, list):
+        return [], {"profile": profile, "error": "invalid worker_roster.json"}
+
+    workers = [
+        _configured_worker_from_roster(profile, index, item)
+        for index, item in enumerate(workers_raw)
+        if isinstance(item, dict)
+    ]
+    return workers, None
+
+
+def _serialize_dashboard_worker_roster() -> Dict[str, Any]:
+    """Return a safe read-only roster of configured and currently running workers."""
+    from hermes_cli.profiles import get_profile_dir, list_profiles
+
+    configured_workers: List[Dict[str, Any]] = []
+    errors: List[Dict[str, str]] = []
+    for profile in list_profiles():
+        workers, error = _load_profile_worker_roster(profile.name, get_profile_dir(profile.name))
+        configured_workers.extend(workers)
+        if error:
+            errors.append(error)
+
+    runtime_workers = [
+        {
+            "id": f"pty:{session.get('id')}",
+            "source": "runtime",
+            "profile": session.get("profile") or "default",
+            "state": "running",
+            "role": "terminal",
+            "lane": None,
+            "mission": None,
+            "preferred_model": None,
+            "capabilities": ["terminal"],
+            "cwd": session.get("cwd"),
+            "terminal_id": session.get("id"),
+            "pid": session.get("pid"),
+            "resume": session.get("resume"),
+            "last_activity": session.get("last_activity"),
+        }
+        for session in _dashboard_pty_sessions_snapshot()
+    ]
+
+    workers = sorted(
+        configured_workers + runtime_workers,
+        key=lambda item: (str(item.get("profile") or ""), str(item.get("source") or ""), str(item.get("id") or "")),
+    )
+    return {
+        "workers": workers,
+        "errors": errors,
+        "counts": {
+            "configured_workers": len(configured_workers),
+            "runtime_workers": len(runtime_workers),
+            "workers": len(workers),
+            "errors": len(errors),
+        },
+    }
+
+
+@app.get("/api/dashboard/worker-roster")
+async def get_dashboard_worker_roster():
+    """Return safe worker roster metadata for the dashboard control plane."""
+    try:
+        return _serialize_dashboard_worker_roster()
+    except Exception:
+        _log.exception("GET /api/dashboard/worker-roster failed")
+        raise HTTPException(status_code=500, detail="Internal server error")
+
+
