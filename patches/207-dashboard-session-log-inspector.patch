@@ -0,0 +1,177 @@
+"""Tests for profile-aware dashboard session/log inspector endpoints."""
+
+from __future__ import annotations
+
+import os
+from pathlib import Path
+
+import pytest
+
+
+def _client_with_dashboard_token():
+    try:
+        from starlette.testclient import TestClient
+    except ImportError:
+        pytest.skip("fastapi/starlette not installed")
+
+    from hermes_cli.web_server import app, _SESSION_HEADER_NAME, _SESSION_TOKEN
+
+    client = TestClient(app)
+    client.headers[_SESSION_HEADER_NAME] = _SESSION_TOKEN
+    return client
+
+
+def _make_profile(root: Path, name: str) -> Path:
+    profile_dir = root / "profiles" / name
+    for subdir in ("logs", "skills", "home", "workspace"):
+        (profile_dir / subdir).mkdir(parents=True, exist_ok=True)
+    (profile_dir / "config.yaml").write_text(
+        "model:\n  default: inspector-model\n  provider: openrouter\n",
+        encoding="utf-8",
+    )
+    return profile_dir
+
+
+def _seed_session(profile_dir: Path) -> None:
+    from hermes_state import SessionDB
+
+    db = SessionDB(db_path=profile_dir / "state.db")
+    try:
+        db.create_session(
+            "inspect-session",
+            source="dashboard-test",
+            model="inspector-model",
+            system_prompt="SYSTEM SECRET: do not expose this",
+        )
+        db.append_message(
+            "inspect-session",
+            role="user",
+            content="hello with API_KEY=super-secret-user-message",
+            token_count=7,
+        )
+        db.append_message(
+            "inspect-session",
+            role="assistant",
+            content="assistant body should not be exposed",
+            tool_calls=[{"name": "terminal", "arguments": {"secret": "hidden"}}],
+            token_count=11,
+            finish_reason="tool_calls",
+        )
+        db.append_message(
+            "inspect-session",
+            role="tool",
+            content="tool output with TOKEN=super-secret-tool-output",
+            tool_name="terminal",
+            tool_call_id="call-1",
+            token_count=5,
+        )
+        db.update_token_counts(
+            "inspect-session",
+            input_tokens=10,
+            output_tokens=20,
+            model="inspector-model",
+            estimated_cost_usd=0.0123,
+            api_call_count=2,
+        )
+    finally:
+        db.close()
+
+
+class TestDashboardProfileInspectorApi:
+    def test_profile_sessions_endpoint_returns_safe_metadata_only(self):
+        root = Path(os.environ["HERMES_HOME"])
+        profile_dir = _make_profile(root, "coder")
+        _seed_session(profile_dir)
+
+        response = _client_with_dashboard_token().get("/api/dashboard/profiles/coder/sessions")
+
+        assert response.status_code == 200
+        payload = response.json()
+        assert payload["profile"] == "coder"
+        assert payload["total"] == 1
+        session = payload["sessions"][0]
+        assert session["session_id"] == "inspect-session"
+        assert session["source"] == "dashboard-test"
+        assert session["model"] == "inspector-model"
+        assert session["message_count"] == 3
+        assert session["tool_call_count"] == 1
+        assert session["token_counts"]["input"] == 10
+        assert session["token_counts"]["output"] == 20
+        assert "system_prompt" not in session
+        assert "model_config" not in session
+        assert "super-secret" not in str(payload)
+        assert "SYSTEM SECRET" not in str(payload)
+
+    def test_profile_session_detail_returns_message_and_tool_summaries_without_bodies(self):
+        root = Path(os.environ["HERMES_HOME"])
+        profile_dir = _make_profile(root, "coder")
+        _seed_session(profile_dir)
+
+        response = _client_with_dashboard_token().get(
+            "/api/dashboard/profiles/coder/sessions/inspect-session"
+        )
+
+        assert response.status_code == 200
+        payload = response.json()
+        assert payload["profile"] == "coder"
+        assert payload["session"]["session_id"] == "inspect-session"
+        assert payload["messages"][0]["role"] == "user"
+        assert payload["messages"][0]["has_content"] is True
+        assert payload["messages"][0]["content_length"] > 0
+        assert payload["messages"][1]["tool_call_count"] == 1
+        assert payload["messages"][2]["tool_name"] == "terminal"
+        assert payload["tool_calls"] == [{"message_index": 1, "role": "assistant", "tool_name": None}]
+        assert "content" not in payload["messages"][0]
+        assert "tool_calls" not in payload["messages"][1]
+        assert "super-secret" not in str(payload)
+        assert "assistant body" not in str(payload)
+        assert "SYSTEM SECRET" not in str(payload)
+
+    def test_profile_logs_endpoint_returns_metadata_not_log_contents(self):
+        root = Path(os.environ["HERMES_HOME"])
+        profile_dir = _make_profile(root, "coder")
+        (profile_dir / "logs" / "agent.log").write_text(
+            "INFO hello\nERROR SECRET_TOKEN=hidden\n",
+            encoding="utf-8",
+        )
+
+        response = _client_with_dashboard_token().get("/api/dashboard/profiles/coder/logs")
+
+        assert response.status_code == 200
+        payload = response.json()
+        assert payload["profile"] == "coder"
+        assert payload["total"] == 1
+        log = payload["logs"][0]
+        assert log["name"] == "agent.log"
+        assert log["size_bytes"] > 0
+        assert "SECRET_TOKEN" not in str(payload)
+        assert "INFO hello" not in str(payload)
+
+    def test_profile_inspector_rejects_invalid_missing_or_cross_profile_sessions(self):
+        root = Path(os.environ["HERMES_HOME"])
+        coder_dir = _make_profile(root, "coder")
+        other_dir = _make_profile(root, "other")
+        _seed_session(coder_dir)
+        _seed_session(other_dir)
+
+        client = _client_with_dashboard_token()
+
+        invalid = client.get("/api/dashboard/profiles/INVALID!/sessions")
+        missing_profile = client.get("/api/dashboard/profiles/missing/sessions")
+        missing_session = client.get("/api/dashboard/profiles/coder/sessions/nope")
+
+        assert invalid.status_code == 400
+        assert missing_profile.status_code == 404
+        assert missing_session.status_code == 404
+
+    def test_profile_inspector_requires_dashboard_session_token(self):
+        try:
+            from starlette.testclient import TestClient
+        except ImportError:
+            pytest.skip("fastapi/starlette not installed")
+
+        from hermes_cli.web_server import app
+
+        response = TestClient(app).get("/api/dashboard/profiles/default/sessions")
+
+        assert response.status_code == 401
