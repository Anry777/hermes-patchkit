+@app.get("/api/dashboard/profiles/{name}/sessions")
+async def get_dashboard_profile_sessions(name: str, limit: int = 20, offset: int = 0):
+    """Return safe profile-local session metadata without message bodies."""
+    if limit < 1 or limit > 100:
+        raise HTTPException(status_code=400, detail="limit must be between 1 and 100")
+    if offset < 0:
+        raise HTTPException(status_code=400, detail="offset must be non-negative")
+    try:
+        profile_dir = _dashboard_profile_dir_or_raise(name)
+        data = _profile_sessions_inspector(profile_dir, limit=limit, offset=offset)
+        data["profile"] = name
+        return data
+    except HTTPException:
+        raise
+    except Exception:
+        _log.exception("GET /api/dashboard/profiles/%s/sessions failed", name)
+        raise HTTPException(status_code=500, detail="Internal server error")
+
+
+@app.get("/api/dashboard/profiles/{name}/sessions/{session_id}")
+async def get_dashboard_profile_session(name: str, session_id: str):
+    """Return safe message/tool metadata for one profile-local session."""
+    try:
+        profile_dir = _dashboard_profile_dir_or_raise(name)
+        data = _profile_session_detail(profile_dir, session_id)
+        data["profile"] = name
+        return data
+    except HTTPException:
+        raise
+    except Exception:
+        _log.exception(
+            "GET /api/dashboard/profiles/%s/sessions/%s failed",
+            name,
+            session_id,
+        )
+        raise HTTPException(status_code=500, detail="Internal server error")
+
+
+@app.get("/api/dashboard/profiles/{name}/logs")
+async def get_dashboard_profile_logs(name: str, limit: int = 50):
+    """Return safe profile-local log file metadata without log contents."""
+    if limit < 1 or limit > 200:
+        raise HTTPException(status_code=400, detail="limit must be between 1 and 200")
+    try:
+        profile_dir = _dashboard_profile_dir_or_raise(name)
+        logs = _profile_log_summaries(profile_dir, limit=limit)
+        return {"profile": name, "total": len(logs), "logs": logs, "limit": limit}
+    except HTTPException:
+        raise
+    except Exception:
+        _log.exception("GET /api/dashboard/profiles/%s/logs failed", name)
+        raise HTTPException(status_code=500, detail="Internal server error")
+
