+def _safe_dashboard_session_row(item: Dict[str, Any], *, now: Optional[float] = None) -> Dict[str, Any]:
+    """Return safe session metadata without prompts, configs, or message bodies."""
+    now_ts = time.time() if now is None else now
+    started_at = item.get("started_at") or 0
+    last_active = item.get("last_active", started_at) or started_at
+    session_id = item.get("id") or item.get("session_id")
+    return {
+        "id": session_id,
+        "session_id": session_id,
+        "source": item.get("source"),
+        "model": item.get("model"),
+        "title": item.get("title"),
+        "started_at": item.get("started_at"),
+        "ended_at": item.get("ended_at"),
+        "end_reason": item.get("end_reason"),
+        "last_active": last_active,
+        "message_count": item.get("message_count", 0) or 0,
+        "tool_call_count": item.get("tool_call_count", 0) or 0,
+        "token_counts": {
+            "input": item.get("input_tokens", 0) or 0,
+            "output": item.get("output_tokens", 0) or 0,
+            "cache_read": item.get("cache_read_tokens", 0) or 0,
+            "cache_write": item.get("cache_write_tokens", 0) or 0,
+            "reasoning": item.get("reasoning_tokens", 0) or 0,
+        },
+        "estimated_cost_usd": item.get("estimated_cost_usd", 0) or 0,
+        "api_call_count": item.get("api_call_count", 0) or 0,
+        "is_active": item.get("ended_at") is None and (now_ts - last_active) < 300,
+    }
+
+
+def _safe_dashboard_message_summary(index: int, item: Dict[str, Any]) -> Dict[str, Any]:
+    """Return message metadata without body text or raw tool arguments."""
+    raw_tool_calls = item.get("tool_calls")
+    if isinstance(raw_tool_calls, list):
+        tool_call_count = len(raw_tool_calls)
+    elif raw_tool_calls:
+        tool_call_count = 1
+    else:
+        tool_call_count = 0
+
+    content = item.get("content")
+    reasoning = item.get("reasoning") or item.get("reasoning_content")
+    return {
+        "index": index,
+        "message_id": item.get("id"),
+        "role": item.get("role"),
+        "timestamp": item.get("timestamp"),
+        "token_count": item.get("token_count"),
+        "finish_reason": item.get("finish_reason"),
+        "tool_name": item.get("tool_name"),
+        "tool_call_id": item.get("tool_call_id"),
+        "tool_call_count": tool_call_count,
+        "has_content": bool(content),
+        "content_length": len(content) if isinstance(content, str) else 0,
+        "has_reasoning": bool(reasoning),
+    }
+
+
+def _safe_dashboard_tool_call_summaries(messages: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
+    """Return tool-call presence without raw tool arguments."""
+    summaries: List[Dict[str, Any]] = []
+    for index, item in enumerate(messages):
+        raw_tool_calls = item.get("tool_calls")
+        if not raw_tool_calls:
+            continue
+        count = len(raw_tool_calls) if isinstance(raw_tool_calls, list) else 1
+        for _ in range(count):
+            summaries.append({
+                "message_index": index,
+                "role": item.get("role"),
+                "tool_name": item.get("tool_name"),
+            })
+    return summaries
+
