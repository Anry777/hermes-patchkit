+    db = SessionDB(db_path=db_path)
+    try:
+        session = db.get_session(session_id)
+        if session is None:
+            raise HTTPException(status_code=404, detail=f"Session '{session_id}' not found")
+        messages = db.get_messages(session_id)
+    finally:
+        db.close()
