index bc1c75859..9412cd61f 100644
--- a/hermes_cli/web_server.py
+++ b/hermes_cli/web_server.py
@@ -1390,6 +1390,83 @@ _ACTION_LOG_FILES: Dict[str, str] = {
 _ACTION_PROCS: Dict[str, subprocess.Popen] = {}
 
 
+_CONTROLLED_DASHBOARD_ACTIONS: Dict[str, Dict[str, Any]] = {
+    "gateway-restart": {
+        "id": "gateway-restart",
+        "label": "Restart gateway",
+        "description": "Restart the Hermes messaging gateway in a detached non-interactive process.",
+        "subcommand": ["gateway", "restart"],
+        "confirmation": "RUN gateway-restart",
+        "danger_level": "medium",
+    },
+    "hermes-update": {
+        "id": "hermes-update",
+        "label": "Update Hermes",
+        "description": "Run hermes update in the current checkout/venv. Review logs after it finishes.",
+        "subcommand": ["update"],
+        "confirmation": "RUN hermes-update",
+        "danger_level": "high",
+    },
+}
+
+
+def _serialize_dashboard_action(action: Dict[str, Any]) -> Dict[str, Any]:
+    return {
+        "id": action["id"],
+        "label": action["label"],
+        "description": action["description"],
+        "confirmation": action["confirmation"],
+        "requires_confirmation": True,
+        "danger_level": action["danger_level"],
+        "status_name": action["id"],
+    }
+
+
+def _run_controlled_dashboard_action(action_id: str, confirmation: str) -> Dict[str, Any]:
+    action = _CONTROLLED_DASHBOARD_ACTIONS.get(action_id)
+    if action is None:
+        raise HTTPException(status_code=404, detail=f"Unknown dashboard action: {action_id}")
+    expected = action["confirmation"]
+    if not confirmation or not hmac.compare_digest(str(confirmation), expected):
+        raise HTTPException(
+            status_code=400,
+            detail=f"Invalid confirmation. Type exactly: {expected}",
+        )
+    try:
+        proc = _spawn_hermes_action(list(action["subcommand"]), action_id)
+    except Exception as exc:
+        _log.exception("Failed to spawn controlled dashboard action %s", action_id)
+        raise HTTPException(status_code=500, detail=f"Failed to start action: {exc}")
+    return {
+        "ok": True,
+        "pid": proc.pid,
+        "name": action_id,
+        "action_id": action_id,
+    }
+
+
+@app.get("/api/dashboard/actions")
+async def list_dashboard_actions():
+    """List allowlisted mutation actions exposed by the dashboard."""
+    return {
+        "actions": [
+            _serialize_dashboard_action(action)
+            for action in _CONTROLLED_DASHBOARD_ACTIONS.values()
+        ]
+    }
+
+
+@app.post("/api/dashboard/actions/{action_id}/run")
+async def run_dashboard_action(action_id: str, request: Request):
+    """Run a single allowlisted dashboard action after exact confirmation."""
+    try:
+        body = await request.json()
+    except Exception:
+        body = {}
+    confirmation = body.get("confirmation", "") if isinstance(body, dict) else ""
+    return _run_controlled_dashboard_action(action_id, confirmation)
+
+
 def _spawn_hermes_action(subcommand: List[str], name: str) -> subprocess.Popen:
     """Spawn ``hermes <subcommand>`` detached and record the Popen handle.
 
