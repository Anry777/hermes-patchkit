+"""Tests for dashboard controlled action endpoints."""
+
+from __future__ import annotations
+
+import pytest
+
+
+def _client_with_dashboard_token():
+    try:
+        from starlette.testclient import TestClient
+    except ImportError:
+        pytest.skip("fastapi/starlette not installed")
+
+    from hermes_cli.web_server import app, _SESSION_HEADER_NAME, _SESSION_TOKEN
+
+    client = TestClient(app)
+    client.headers[_SESSION_HEADER_NAME] = _SESSION_TOKEN
+    return client
+
+
+class TestDashboardControlledActionsApi:
+    def test_controlled_actions_requires_dashboard_session_token(self):
+        try:
+            from starlette.testclient import TestClient
+        except ImportError:
+            pytest.skip("fastapi/starlette not installed")
+
+        from hermes_cli.web_server import app
+
+        assert TestClient(app).get("/api/dashboard/actions").status_code == 401
+        assert (
+            TestClient(app)
+            .post("/api/dashboard/actions/gateway-restart/run", json={"confirmation": "RUN gateway-restart"})
+            .status_code
+            == 401
+        )
+
+    def test_controlled_actions_list_is_allowlisted_and_safe(self):
+        response = _client_with_dashboard_token().get("/api/dashboard/actions")
+
+        assert response.status_code == 200
+        payload = response.json()
+        actions = {item["id"]: item for item in payload["actions"]}
+        assert set(actions) == {"gateway-restart", "hermes-update"}
+        assert actions["gateway-restart"]["confirmation"] == "RUN gateway-restart"
+        assert actions["hermes-update"]["requires_confirmation"] is True
+        assert actions["hermes-update"]["danger_level"] == "high"
+        assert "api_key" not in str(payload).lower()
+        assert ".env" not in str(payload)
+
+    def test_controlled_action_rejects_missing_confirmation_and_unknown_action(self):
+        client = _client_with_dashboard_token()
+
+        missing = client.post("/api/dashboard/actions/gateway-restart/run", json={})
+        assert missing.status_code == 400
+        assert "confirmation" in missing.json()["detail"].lower()
+
+        wrong = client.post(
+            "/api/dashboard/actions/gateway-restart/run",
+            json={"confirmation": "gateway-restart"},
+        )
+        assert wrong.status_code == 400
+
+        unknown = client.post(
+            "/api/dashboard/actions/rm-rf/run",
+            json={"confirmation": "RUN rm-rf"},
+        )
+        assert unknown.status_code == 404
+
+    def test_controlled_action_spawns_only_allowlisted_command(self, monkeypatch):
+        from hermes_cli import web_server
+
+        calls = []
+
+        class FakeProc:
+            pid = 4242
+
+        def fake_spawn(subcommand, name):
+            calls.append((subcommand, name))
+            return FakeProc()
+
+        monkeypatch.setattr(web_server, "_spawn_hermes_action", fake_spawn)
+
+        response = _client_with_dashboard_token().post(
+            "/api/dashboard/actions/gateway-restart/run",
+            json={"confirmation": "RUN gateway-restart"},
+        )
+
+        assert response.status_code == 200
+        assert response.json() == {
+            "ok": True,
+            "pid": 4242,
+            "name": "gateway-restart",
+            "action_id": "gateway-restart",
+        }
+        assert calls == [(["gateway", "restart"], "gateway-restart")]
