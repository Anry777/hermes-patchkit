 from typing import Any, Dict, List, Optional, Tuple
 
@@ -920,6 +921,144 @@ async def get_dashboard_assembly_analytics(days: int = 30):
         raise HTTPException(status_code=500, detail="Internal server error")
 
 
+def _parse_dashboard_iso_timestamp(value: Any) -> Optional[float]:
+    if not value:
+        return None
+    try:
+        text = str(value).strip()
+        if text.endswith("Z"):
+            text = text[:-1] + "+00:00"
+        return datetime.fromisoformat(text).timestamp()
+    except Exception:
+        return None
+
+
+def _dashboard_platform_rows(runtime: Optional[Dict[str, Any]], now: float) -> List[Dict[str, Any]]:
+    platforms = (runtime or {}).get("platforms") or {}
+    rows: List[Dict[str, Any]] = []
+    stale_after_seconds = 24 * 3600
+    for name, raw in sorted(platforms.items()):
+        info = raw if isinstance(raw, dict) else {}
+        state = str(info.get("state") or "unknown")
+        updated_at = info.get("updated_at")
+        updated_ts = _parse_dashboard_iso_timestamp(updated_at)
+        age_seconds = None if updated_ts is None else max(0, int(now - updated_ts))
+        stale = age_seconds is not None and age_seconds > stale_after_seconds
+        needs_attention = state not in {"connected", "running", "ok"} or stale
+        display_state = "STALE" if state == "connected" and stale else state.upper()
+        rows.append({
+            "name": str(name),
+            "state": state,
+            "display_state": display_state,
+            "needs_attention": needs_attention,
+            "updated_at": updated_at,
+            "age_seconds": age_seconds,
+            "error_code": info.get("error_code"),
+            "error_message": info.get("error_message"),
+        })
+    return rows
+
+
+def _serialize_dashboard_overview() -> Dict[str, Any]:
+    """Unified read-only dashboard control-plane summary.
+
+    Exposes counts and safe process metadata only: no session IDs, message
+    bodies, prompts, tool arguments, env vars, or log contents.  This is the
+    shared semantic contract for Overview, sidebar, and profile/session pages.
+    """
+    now = time.time()
+    analytics = _serialize_dashboard_assembly_analytics(days=30)
+    runtime_registry = _serialize_dashboard_runtime_registry()
+    active_profile = str(analytics.get("active_profile") or "default")
+    profile_rows = list(analytics.get("profiles") or [])
+    totals = dict(analytics.get("totals") or {})
+    current_profile_row = next(
+        (row for row in profile_rows if str(row.get("profile")) == active_profile),
+        {},
+    )
+
+    pty_sessions = list(runtime_registry.get("pty_sessions") or [])
+    terminals_by_profile: Dict[str, int] = {}
+    for session in pty_sessions:
+        profile = str(session.get("profile") or "default")
+        terminals_by_profile[profile] = terminals_by_profile.get(profile, 0) + 1
+
+    gateway_pid = get_running_pid()
+    gateway_running = gateway_pid is not None
+    runtime_status = read_runtime_status()
+    gateway_state = None
+    gateway_updated_at = None
+    if runtime_status:
+        gateway_state = runtime_status.get("gateway_state")
+        gateway_updated_at = runtime_status.get("updated_at")
+        if not gateway_running:
+            gateway_state = gateway_state if gateway_state in ("stopped", "startup_failed") else "stopped"
+    platform_rows = _dashboard_platform_rows(runtime_status, now) if gateway_running else []
+
+    return {
+        "generated_at": datetime.fromtimestamp(now, timezone.utc).isoformat(),
+        "version": __version__,
+        "release_date": __release_date__,
+        "active_profile": active_profile,
+        "model": {
+            "provider": current_profile_row.get("provider"),
+            "name": current_profile_row.get("model"),
+        },
+        "profiles": {
+            "total": int(totals.get("profiles") or len(profile_rows)),
+            "active": int(totals.get("active_profiles") or 0),
+            "stale": int(totals.get("stale_profiles") or 0),
+            "rows": profile_rows,
+        },
+        "sessions": {
+            "total": int(totals.get("total_sessions") or 0),
+            "current_profile_total": int(current_profile_row.get("sessions") or 0),
+            "recently_active_db_records": int(totals.get("active_sessions") or 0),
+            "current_profile_recently_active_db_records": int(current_profile_row.get("active_sessions") or 0),
+        },
+        "terminals": {
+            "active": len(pty_sessions),
+            "by_profile": terminals_by_profile,
+            "sessions": pty_sessions,
+        },
+        "gateway": {
+            "running": gateway_running,
+            "state": gateway_state,
+            "pid": gateway_pid,
+            "updated_at": gateway_updated_at,
+            "platforms": {
+                "total": len(platform_rows),
+                "connected": sum(1 for row in platform_rows if row.get("state") == "connected"),
+                "stale": sum(1 for row in platform_rows if row.get("display_state") == "STALE"),
+                "attention": sum(1 for row in platform_rows if row.get("needs_attention")),
+            },
+            "platform_rows": platform_rows,
+        },
+        "runtime": {
+            "dashboard_pid": (runtime_registry.get("dashboard") or {}).get("pid"),
+            "event_channels": int((runtime_registry.get("counts") or {}).get("event_channels") or 0),
+            "actions": int((runtime_registry.get("counts") or {}).get("actions") or 0),
+        },
+        "semantics": {
+            "historical_sessions": "session DB records across profiles",
+            "recently_active_db_records": "unended session DB records active in the last five minutes",
+            "active_terminals": "live dashboard PTY channels",
+            "connected_platforms": "gateway platform adapters currently reporting connected",
+            "needs_attention": "disconnected, failed, unknown, or stale gateway platform rows",
+        },
+    }
+
+
+@app.get("/api/dashboard/overview")
+async def get_dashboard_overview():
+    """Return the unified dashboard control-plane overview."""
+    try:
+        return _serialize_dashboard_overview()
+    except Exception:
+        _log.exception("GET /api/dashboard/overview failed")
+        raise HTTPException(status_code=500, detail="Internal server error")
+
