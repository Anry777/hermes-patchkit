@@ -0,0 +1,177 @@
+import { useCallback, useEffect, useState } from "react";
+import {
+  AlertTriangle,
+  Activity,
+  Database,
+  Radio,
+  RefreshCw,
+  Terminal,
+  Users,
+} from "lucide-react";
+import { Badge, Button, Spinner } from "@nous-research/ui";
+import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
+import { api } from "@/lib/api";
+import type { DashboardOverviewResponse } from "@/lib/api";
+import { isoTimeAgo } from "@/lib/utils";
+import { PluginSlot } from "@/plugins";
+
+function fmt(n: number): string {
+  return new Intl.NumberFormat(undefined, { notation: n >= 1_000_000 ? "compact" : "standard" }).format(n);
+}
+
+function platformTone(state: string): "success" | "warning" | "destructive" | "outline" {
+  if (state === "connected") return "success";
+  if (state === "stale" || state === "disconnected") return "warning";
+  if (state === "fatal" || state === "error") return "destructive";
+  return "outline";
+}
+
+export default function OverviewPage() {
+  const [overview, setOverview] = useState<DashboardOverviewResponse | null>(null);
+  const [loading, setLoading] = useState(true);
+  const [error, setError] = useState<string | null>(null);
+
+  const load = useCallback(() => {
+    setLoading(true);
+    api
+      .getDashboardOverview()
+      .then((data) => {
+        setOverview(data);
+        setError(null);
+      })
+      .catch((err) => setError(String(err)))
+      .finally(() => setLoading(false));
+  }, []);
+
+  useEffect(() => {
+    // eslint-disable-next-line react-hooks/set-state-in-effect -- initial async fetch sets loading/data state.
+    load();
+    const id = window.setInterval(load, 10_000);
+    return () => window.clearInterval(id);
+  }, [load]);
+
+  if (loading && !overview) {
+    return (
+      <div className="flex items-center justify-center py-24" aria-busy="true">
+        <Spinner className="text-2xl text-primary" />
+      </div>
+    );
+  }
+
+  return (
+    <div className="flex flex-col gap-6" data-dashboard-control-plane-overview>
+      <PluginSlot name="overview:top" />
+
+      <div className="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
+        <div>
+          <p className="text-xs uppercase tracking-[0.18em] text-muted-foreground">
+            Unified control plane
+          </p>
+          <h2 className="text-xl font-semibold tracking-tight">
+            {overview?.active_profile ?? "default"} profile overview
+          </h2>
+        </div>
+        <Button outlined size="sm" onClick={load} disabled={loading}>
+          {loading ? <Spinner /> : <RefreshCw className="h-3.5 w-3.5" />}
+          Refresh
+        </Button>
+      </div>
+
+      {error && (
+        <div className="border border-destructive/30 bg-destructive/[0.06] p-3 text-sm text-destructive">
+          {error}
+        </div>
+      )}
+
+      {overview && (
+        <>
+          <div className="grid gap-3 md:grid-cols-2 xl:grid-cols-4">
+            <MetricCard icon={Database} label="Historical sessions" value={fmt(overview.sessions.total)} detail={`${fmt(overview.sessions.current_profile_total)} in current profile`} />
+            <MetricCard icon={Terminal} label="Active terminals" value={fmt(overview.terminals.active)} detail="Live dashboard PTY channels" />
+            <MetricCard icon={Users} label="Profiles" value={`${overview.profiles.active}/${overview.profiles.total}`} detail={`${overview.profiles.stale} stale`} />
+            <MetricCard icon={Radio} label="Gateway platforms" value={`${overview.gateway.platforms.connected}/${overview.gateway.platforms.total}`} detail={`${overview.gateway.platforms.attention} Needs attention`} />
+          </div>
+
+          <div className="grid gap-4 xl:grid-cols-[1.35fr_0.9fr]">
+            <Card>
+              <CardHeader>
+                <CardTitle className="text-base">Profile health</CardTitle>
+              </CardHeader>
+              <CardContent className="overflow-x-auto">
+                <table className="w-full text-sm">
+                  <thead className="text-xs uppercase tracking-[0.12em] text-muted-foreground">
+                    <tr>
+                      <th className="py-2 pr-3 text-left">Profile</th>
+                      <th className="py-2 pr-3 text-left">Sessions</th>
+                      <th className="py-2 pr-3 text-left">Tokens</th>
+                      <th className="py-2 pr-3 text-left">Tools</th>
+                      <th className="py-2 text-left">Status</th>
+                    </tr>
+                  </thead>
+                  <tbody>
+                    {overview.profiles.rows.map((profile) => (
+                      <tr key={profile.profile} className="border-t border-border/60">
+                        <td className="py-2 pr-3 font-medium uppercase">{profile.profile}</td>
+                        <td className="py-2 pr-3 tabular-nums">{fmt(profile.sessions)}</td>
+                        <td className="py-2 pr-3 tabular-nums">{fmt(profile.input_tokens + profile.output_tokens)}</td>
+                        <td className="py-2 pr-3 tabular-nums">{fmt(profile.tool_calls)}</td>
+                        <td className="py-2">
+                          <Badge tone={profile.stale ? "warning" : "success"} className="text-[10px]">
+                            {profile.stale ? "Stale" : "Active"}
+                          </Badge>
+                        </td>
+                      </tr>
+                    ))}
+                  </tbody>
+                </table>
+              </CardContent>
+            </Card>
+
+            <Card>
+              <CardHeader>
+                <CardTitle className="text-base">Platform freshness</CardTitle>
+              </CardHeader>
+              <CardContent className="grid gap-3">
+                {overview.gateway.platform_rows.length === 0 ? (
+                  <p className="text-sm text-muted-foreground">No gateway platforms reported.</p>
+                ) : (
+                  overview.gateway.platform_rows.map((platform) => (
+                    <div key={platform.name} className="flex items-center justify-between gap-3 border border-border p-3">
+                      <div className="min-w-0">
+                        <p className="truncate text-sm font-medium capitalize">{platform.name}</p>
+                        <p className="text-xs text-muted-foreground">
+                          {platform.updated_at ? `Last event ${isoTimeAgo(platform.updated_at)}` : "No heartbeat"}
+                        </p>
+                      </div>
+                      <Badge tone={platformTone(platform.display_state)} className="text-[10px] shrink-0">
+                        {platform.needs_attention && <AlertTriangle className="mr-1 h-3 w-3" />}
+                        {platform.display_state}
+                      </Badge>
+                    </div>
+                  ))
+                )}
+              </CardContent>
+            </Card>
+          </div>
+        </>
+      )}
+
+      <PluginSlot name="overview:bottom" />
+    </div>
+  );
+}
+
+function MetricCard({ icon: Icon, label, value, detail }: { icon: typeof Activity; label: string; value: string; detail: string }) {
+  return (
+    <Card>
+      <CardContent className="flex items-start gap-3 p-4">
+        <Icon className="mt-0.5 h-4 w-4 shrink-0 text-muted-foreground" />
+        <div className="min-w-0">
+          <p className="text-xs uppercase tracking-[0.12em] text-muted-foreground">{label}</p>
+          <p className="mt-1 text-2xl font-semibold tabular-nums">{value}</p>
+          <p className="mt-1 text-xs text-muted-foreground">{detail}</p>
+        </div>
+      </CardContent>
+    </Card>
+  );
+}
