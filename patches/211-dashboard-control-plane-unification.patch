@@ -0,0 +1,130 @@
+"""Tests for the unified dashboard overview control-plane endpoint."""
+
+from __future__ import annotations
+
+import time
+from pathlib import Path
+
+import pytest
+
+
+def _client_with_dashboard_token():
+    try:
+        from starlette.testclient import TestClient
+    except Exception as exc:  # pragma: no cover - optional dependency guard
+        pytest.skip(f"starlette TestClient unavailable: {exc}")
+
+    import hermes_cli.web_server as ws
+
+    ws._SESSION_TOKEN = "overview-test-token"
+    ws.app.state.session_token = "overview-test-token"
+    return TestClient(ws.app, headers={"X-Hermes-Session-Token": "overview-test-token"})
+
+
+def _seed_session(profile_dir: Path, session_id: str, *, model: str = "gpt-5.5", last_active: float | None = None) -> None:
+    from hermes_state import SessionDB
+
+    profile_dir.mkdir(parents=True, exist_ok=True)
+    db = SessionDB(db_path=profile_dir / "state.db")
+    try:
+        db.create_session(session_id=session_id, source="cli", model=model)
+        db.update_token_counts(session_id, input_tokens=100, output_tokens=20)
+        db.set_session_title(session_id, f"Session {session_id}")
+        if last_active is not None:
+            with db._lock:
+                db._conn.execute(
+                    "UPDATE sessions SET started_at = ?, ended_at = NULL WHERE id = ?",
+                    (last_active, session_id),
+                )
+                db._conn.commit()
+    finally:
+        db.close()
+
+
+def test_dashboard_overview_unifies_counts_and_safe_terms(tmp_path, monkeypatch):
+    import hermes_cli.web_server as ws
+
+    home = tmp_path / ".hermes"
+    home.mkdir()
+    monkeypatch.setattr(Path, "home", lambda: tmp_path)
+    monkeypatch.setenv("HERMES_HOME", str(home))
+    monkeypatch.setenv("HERMES_ACTIVE_PROFILE", "default")
+
+    profile_dir = home / "profiles" / "ops"
+    profile_dir.mkdir(parents=True)
+    (profile_dir / "config.yaml").write_text("model:\n  provider: openai-codex\n  default: gpt-5.5\n", encoding="utf-8")
+
+    now = time.time()
+    _seed_session(home, "default-active", last_active=now)
+    _seed_session(profile_dir, "ops-stale", last_active=now - 10 * 86400)
+
+    monkeypatch.setattr(ws, "get_running_pid", lambda: 12345)
+    monkeypatch.setattr(ws, "read_runtime_status", lambda: {
+        "gateway_state": "running",
+        "updated_at": "2026-05-03T10:00:00+00:00",
+        "platforms": {
+            "telegram": {"state": "connected", "updated_at": "2026-05-01T10:00:00+00:00"},
+            "discord": {"state": "disconnected", "updated_at": "2026-05-03T09:00:00+00:00"},
+        },
+    })
+
+    with ws._PTY_SESSIONS_LOCK:
+        ws._PTY_SESSIONS.clear()
+        ws._PTY_SESSIONS["pty-default"] = {
+            "id": "pty-default",
+            "profile": "default",
+            "pid": 111,
+            "started_at": now,
+            "last_activity": now,
+        }
+
+    client = _client_with_dashboard_token()
+    resp = client.get("/api/dashboard/overview")
+
+    assert resp.status_code == 200
+    data = resp.json()
+    assert data["semantics"]["historical_sessions"] == "session DB records across profiles"
+    assert data["semantics"]["active_terminals"] == "live dashboard PTY channels"
+    assert data["profiles"]["total"] >= 2
+    assert data["sessions"]["total"] >= 2
+    assert data["sessions"]["current_profile_total"] >= 1
+    assert data["terminals"]["active"] == 1
+    assert data["gateway"]["running"] is True
+    assert data["gateway"]["platforms"]["connected"] == 1
+    assert data["gateway"]["platforms"]["attention"] >= 1
+
+    payload = str(data).lower()
+    assert "default-active" not in payload
+    assert "ops-stale" not in payload
+    assert "prompt" not in payload
+    assert "message bodies" not in payload
+
+
+def test_dashboard_overview_is_protected():
+    try:
+        from starlette.testclient import TestClient
+    except Exception as exc:  # pragma: no cover
+        pytest.skip(f"starlette TestClient unavailable: {exc}")
+
+    import hermes_cli.web_server as ws
+
+    ws._SESSION_TOKEN = "overview-test-token"
+    ws.app.state.session_token = "overview-test-token"
+    resp = TestClient(ws.app).get("/api/dashboard/overview")
+    assert resp.status_code == 401
+
+
+def test_example_dashboard_plugin_is_hidden_by_default(monkeypatch):
+    import hermes_cli.web_server as ws
+
+    monkeypatch.delenv("HERMES_DASHBOARD_SHOW_EXAMPLES", raising=False)
+    plugins = ws._discover_dashboard_plugins()
+    assert all(plugin["name"] != "example" for plugin in plugins)
+
+
+def test_example_dashboard_plugin_can_be_enabled_for_development(monkeypatch):
+    import hermes_cli.web_server as ws
+
+    monkeypatch.setenv("HERMES_DASHBOARD_SHOW_EXAMPLES", "1")
+    plugins = ws._discover_dashboard_plugins()
+    assert any(plugin["name"] == "example" for plugin in plugins)
