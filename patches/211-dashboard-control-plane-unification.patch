+function isStalePlatform(updatedAt?: string | null): boolean {
+  if (!updatedAt) return false;
+  const ts = Date.parse(updatedAt);
+  if (!Number.isFinite(ts)) return false;
+  return Date.now() - ts > 24 * 60 * 60 * 1000;
+}
