+    def _is_attachment_not_ready_response(cls, response: Any) -> bool:
+        status_code = getattr(response, "status_code", 200)
+        if status_code < 400:
+            return False
+        payload: Any = None
+        try:
+            payload = response.json()
+        except Exception:
