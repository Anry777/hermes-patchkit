+def test_profile_auth_reads_shared_root_store_even_when_profile_auth_exists(tmp_path, monkeypatch):
+    root_home = tmp_path / ".hermes"
+    profile_home = root_home / "profiles" / "coder"
+    profile_home.mkdir(parents=True, exist_ok=True)
+    (root_home / "auth.json").write_text(json.dumps({
+        "version": 1,
+        "active_provider": "nous",
+        "providers": {
+            "nous": {"access_token": "root-auth-value"},
+        },
+    }))
+    (profile_home / "auth.json").write_text(json.dumps({
+        "version": 1,
+        "active_provider": "nous",
+        "providers": {
+            "nous": {"access_token": "stale-profile-value"},
+        },
+    }))
+    monkeypatch.setattr("pathlib.Path.home", lambda: tmp_path)
+    monkeypatch.setenv("HERMES_HOME", str(profile_home))
+
+    from hermes_cli.auth import _auth_file_path, _auth_lock_path, _load_auth_store
+
+    payload = _load_auth_store()
+    assert payload["active_provider"] == "nous"
+    assert payload["providers"]["nous"]["access_token"] == "root-auth-value"
+    assert _auth_file_path() == root_home / "auth.json"
+    assert _auth_lock_path() == root_home / "auth.lock"
+
+
+def test_profile_auth_writes_mutate_shared_root_store_not_profile_store(tmp_path, monkeypatch):
+    root_home = tmp_path / ".hermes"
+    profile_home = root_home / "profiles" / "coder"
+    profile_home.mkdir(parents=True, exist_ok=True)
+    root_payload = {
+        "version": 1,
+        "active_provider": "anthropic",
+        "providers": {
+            "anthropic": {"access_token": "root-auth-value"},
+        },
+        "credential_pool": {
+            "anthropic": [
+                {
+                    "id": "cred-1",
+                    "label": "root-cred",
+                    "auth_type": "oauth",
+                    "priority": 0,
+                    "source": "manual:hermes_pkce",
+                    "access_token": "root-pool-value",
+                }
+            ],
+            "openrouter": [
+                {
+                    "id": "cred-2",
+                    "label": "shared-other-provider",
+                    "auth_type": "api_key",
+                    "priority": 0,
+                    "source": "manual",
+                    "access_token": "root-openrouter-value",
+                }
+            ],
+        },
+    }
+    profile_payload = {
+        "version": 1,
+        "active_provider": "anthropic",
+        "providers": {
+            "anthropic": {"access_token": "stale-profile-value"},
+        },
+    }
+    (root_home / "auth.json").write_text(json.dumps(root_payload, indent=2))
+    (profile_home / "auth.json").write_text(json.dumps(profile_payload, indent=2))
+    monkeypatch.setattr("pathlib.Path.home", lambda: tmp_path)
+    monkeypatch.setenv("HERMES_HOME", str(profile_home))
+
+    from hermes_cli.auth import clear_provider_auth
+
+    assert clear_provider_auth("anthropic") is True
+
+    root_after = json.loads((root_home / "auth.json").read_text())
+    assert root_after["active_provider"] is None
+    assert "anthropic" not in root_after.get("providers", {})
+    assert "anthropic" not in root_after.get("credential_pool", {})
+    assert "openrouter" in root_after.get("credential_pool", {})
+
+    profile_after = json.loads((profile_home / "auth.json").read_text())
+    assert profile_after == profile_payload
+
+
