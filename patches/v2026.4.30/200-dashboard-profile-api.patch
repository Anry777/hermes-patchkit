+"""Tests for dashboard profile inventory API endpoints."""
+
+from __future__ import annotations
+
+import os
+from pathlib import Path
+
+import pytest
+
+
+def _client_with_dashboard_token():
+    try:
+        from starlette.testclient import TestClient
+    except ImportError:
+        pytest.skip("fastapi/starlette not installed")
+
+    from hermes_cli.web_server import app, _SESSION_HEADER_NAME, _SESSION_TOKEN
+
+    client = TestClient(app)
+    client.headers[_SESSION_HEADER_NAME] = _SESSION_TOKEN
+    return client
+
+
+def _make_profile(root: Path, name: str, *, model: str, provider: str | None = None) -> Path:
+    profile_dir = root / "profiles" / name
+    for subdir in ("sessions", "logs", "skills", "memories", "cron", "workspace", "home"):
+        (profile_dir / subdir).mkdir(parents=True, exist_ok=True)
+    if provider:
+        (profile_dir / "config.yaml").write_text(
+            f"model:\n  default: {model}\n  provider: {provider}\n",
+            encoding="utf-8",
+        )
+    else:
+        (profile_dir / "config.yaml").write_text(f"model: {model}\n", encoding="utf-8")
+    return profile_dir
+
+
+class TestDashboardProfilesApi:
+    def test_profiles_endpoint_lists_default_and_named_profiles(self):
+        root = Path(os.environ["HERMES_HOME"])
+        (root / "config.yaml").write_text(
+            "model:\n  default: default-model\n  provider: openrouter\n",
+            encoding="utf-8",
+        )
+        (root / ".env").write_text("OPENROUTER_API_KEY=secret\n", encoding="utf-8")
+        (root / "skills" / "base" / "SKILL.md").parent.mkdir(parents=True, exist_ok=True)
+        (root / "skills" / "base" / "SKILL.md").write_text("---\nname: base\n---\n", encoding="utf-8")
+
+        coder_dir = _make_profile(root, "coder", model="coder-model", provider="anthropic")
+        (coder_dir / ".env").write_text("ANTHROPIC_API_KEY=secret\n", encoding="utf-8")
+        (coder_dir / "skills" / "coding" / "SKILL.md").parent.mkdir(parents=True, exist_ok=True)
+        (coder_dir / "skills" / "coding" / "SKILL.md").write_text("---\nname: coding\n---\n", encoding="utf-8")
+        (root / "active_profile").write_text("coder\n", encoding="utf-8")
+
+        response = _client_with_dashboard_token().get("/api/dashboard/profiles")
+
+        assert response.status_code == 200
+        payload = response.json()
+        assert payload["active_profile"] == "coder"
+        assert payload["total"] == 2
+
+        profiles = {item["name"]: item for item in payload["profiles"]}
+        assert profiles["default"]["is_default"] is True
+        assert profiles["default"]["is_active"] is False
+        assert profiles["default"]["path"] == str(root)
+        assert profiles["default"]["model"] == "default-model"
+        assert profiles["default"]["provider"] == "openrouter"
+        assert profiles["default"]["has_env"] is True
+        assert profiles["default"]["skill_count"] == 1
+
+        assert profiles["coder"]["is_default"] is False
+        assert profiles["coder"]["is_active"] is True
+        assert profiles["coder"]["path"] == str(coder_dir)
+        assert profiles["coder"]["model"] == "coder-model"
+        assert profiles["coder"]["provider"] == "anthropic"
+        assert profiles["coder"]["has_env"] is True
+        assert profiles["coder"]["skill_count"] == 1
+
+    def test_profile_detail_endpoint_returns_read_only_runtime_metadata(self):
+        root = Path(os.environ["HERMES_HOME"])
+        coder_dir = _make_profile(root, "coder", model="coder-model", provider="anthropic")
+        (coder_dir / ".env").write_text("ANTHROPIC_API_KEY=secret\n", encoding="utf-8")
+        (coder_dir / "logs" / "agent.log").write_text("first line\nsecond line\n", encoding="utf-8")
+
+        from hermes_state import SessionDB
+
+        db = SessionDB(db_path=coder_dir / "state.db")
+        try:
+            db.create_session("session-1", source="dashboard-test", model="coder-model")
+        finally:
+            db.close()
+
+        response = _client_with_dashboard_token().get("/api/dashboard/profiles/coder")
+
+        assert response.status_code == 200
+        payload = response.json()
+        assert payload["name"] == "coder"
+        assert payload["path"] == str(coder_dir)
+        assert payload["config_path"] == str(coder_dir / "config.yaml")
+        assert payload["env_path"] == str(coder_dir / ".env")
+        assert payload["has_env"] is True
+        assert payload["model"] == "coder-model"
+        assert payload["provider"] == "anthropic"
+        assert payload["sessions"]["total"] == 1
+        assert payload["sessions"]["recent"][0]["session_id"] == "session-1"
+
+        log_files = {item["name"]: item for item in payload["logs"]}
+        assert "agent.log" in log_files
+        assert log_files["agent.log"]["size_bytes"] > 0
+        assert "first line" not in str(log_files["agent.log"])
+        assert "ANTHROPIC_API_KEY" not in str(payload)
+        assert "secret" not in str(payload)
+
+    def test_profile_detail_rejects_invalid_or_missing_profiles(self):
+        client = _client_with_dashboard_token()
+
+        invalid = client.get("/api/dashboard/profiles/INVALID!")
+        missing = client.get("/api/dashboard/profiles/missing")
+
+        assert invalid.status_code == 400
+        assert missing.status_code == 404
+
+    def test_profiles_endpoint_requires_dashboard_session_token(self):
+        try:
+            from starlette.testclient import TestClient
+        except ImportError:
+            pytest.skip("fastapi/starlette not installed")
+
+        from hermes_cli.web_server import app
+
+        response = TestClient(app).get("/api/dashboard/profiles")
+
+        assert response.status_code == 401
