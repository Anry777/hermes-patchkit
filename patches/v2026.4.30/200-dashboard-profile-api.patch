+def _profile_info_to_dashboard_dict(profile: Any, active_profile: str) -> Dict[str, Any]:
+    """Serialize ``hermes_cli.profiles.ProfileInfo`` for dashboard consumers.
+
+    Keep this intentionally read-only and metadata-only: never include dotenv
+    values, auth files, memory contents, or session messages.
+    """
+    return {
+        "name": profile.name,
+        "path": str(profile.path),
+        "is_default": profile.is_default,
+        "is_active": profile.name == active_profile,
+        "gateway_running": profile.gateway_running,
+        "model": profile.model,
+        "provider": profile.provider,
+        "has_env": profile.has_env,
+        "skill_count": profile.skill_count,
+        "alias_path": str(profile.alias_path) if profile.alias_path else None,
+    }
+
+
+def _profile_log_summaries(profile_dir: Path, limit: int = 20) -> List[Dict[str, Any]]:
+    """Return safe log-file metadata for a profile without reading contents."""
+    logs_dir = profile_dir / "logs"
+    if not logs_dir.is_dir():
+        return []
+
+    entries: List[Dict[str, Any]] = []
+    try:
+        candidates = [p for p in logs_dir.iterdir() if p.is_file()]
+    except OSError:
+        return []
+
+    for path in sorted(candidates, key=lambda p: p.stat().st_mtime if p.exists() else 0, reverse=True)[:limit]:
+        try:
+            stat = path.stat()
+        except OSError:
+            continue
+        entries.append({
+            "name": path.name,
+            "path": str(path),
+            "size_bytes": stat.st_size,
+            "modified_at": stat.st_mtime,
+        })
+    return entries
+
+
+def _profile_session_summary(profile_dir: Path, limit: int = 5) -> Dict[str, Any]:
+    """Return session counts/recent metadata for a profile if its DB exists."""
+    db_path = profile_dir / "state.db"
+    if not db_path.exists():
+        return {"total": 0, "active": 0, "recent": []}
+
+    try:
+        from hermes_state import SessionDB
+
+        db = SessionDB(db_path=db_path)
+        try:
+            recent = db.list_sessions_rich(limit=limit)
+            total = db.session_count()
+        finally:
+            db.close()
+    except Exception:
+        _log.exception("Failed to summarize profile sessions for %s", profile_dir)
+        return {"total": 0, "active": 0, "recent": []}
+
+    safe_recent: List[Dict[str, Any]] = []
+    for session in recent:
+        session_id = session.get("id")
+        safe_recent.append({
+            "id": session_id,
+            "session_id": session_id,
+            "source": session.get("source"),
+            "model": session.get("model"),
+            "title": session.get("title"),
+            "started_at": session.get("started_at"),
+            "ended_at": session.get("ended_at"),
+            "end_reason": session.get("end_reason"),
+            "last_active": session.get("last_active"),
+            "message_count": session.get("message_count"),
+            "tool_call_count": session.get("tool_call_count"),
+        })
+
+    now = time.time()
+    active = sum(
+        1 for session in safe_recent
+        if session.get("ended_at") is None
+        and (now - session.get("last_active", session.get("started_at", 0))) < 300
+    )
+    return {"total": total, "active": active, "recent": safe_recent}
+
+
+@app.get("/api/dashboard/profiles")
+async def get_dashboard_profiles():
+    """Return read-only profile inventory for the dashboard control plane."""
+    try:
+        from hermes_cli.profiles import get_active_profile, list_profiles
+
+        active_profile = get_active_profile()
+        profiles = [
+            _profile_info_to_dashboard_dict(profile, active_profile)
+            for profile in list_profiles()
+        ]
+        return {
+            "active_profile": active_profile,
+            "total": len(profiles),
+            "profiles": profiles,
+        }
+    except Exception:
+        _log.exception("GET /api/dashboard/profiles failed")
+        raise HTTPException(status_code=500, detail="Internal server error")
+
+
+@app.get("/api/dashboard/profiles/{name}")
+async def get_dashboard_profile(name: str):
+    """Return read-only metadata for a single dashboard profile."""
+    try:
+        from hermes_cli.profiles import (
+            get_active_profile,
+            get_profile_dir,
+            list_profiles,
+            profile_exists,
+            validate_profile_name,
+        )
+
+        try:
+            validate_profile_name(name)
+        except ValueError as exc:
+            raise HTTPException(status_code=400, detail=str(exc)) from exc
+
+        if not profile_exists(name):
+            raise HTTPException(status_code=404, detail=f"Profile '{name}' not found")
+
+        active_profile = get_active_profile()
+        profile_map = {profile.name: profile for profile in list_profiles()}
+        profile = profile_map.get(name)
+        if profile is None:
+            raise HTTPException(status_code=404, detail=f"Profile '{name}' not found")
+
+        profile_dir = get_profile_dir(name)
+        data = _profile_info_to_dashboard_dict(profile, active_profile)
+        data.update({
+            "config_path": str(profile_dir / "config.yaml"),
+            "env_path": str(profile_dir / ".env"),
+            "sessions": _profile_session_summary(profile_dir),
+            "logs": _profile_log_summaries(profile_dir),
+        })
+        return data
+    except HTTPException:
+        raise
+    except Exception:
+        _log.exception("GET /api/dashboard/profiles/%s failed", name)
+        raise HTTPException(status_code=500, detail="Internal server error")
+
+
 @app.get("/api/status")
