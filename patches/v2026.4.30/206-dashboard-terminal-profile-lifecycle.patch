+@app.delete("/api/dashboard/runtimes/pty/{session_id}")
+async def close_dashboard_pty_session(session_id: str):
+    """Close one dashboard PTY session by its opaque registry id."""
+    if not _VALID_CHANNEL_RE.match(session_id):
+        raise HTTPException(status_code=400, detail="Invalid PTY session id")
+
+    with _PTY_SESSIONS_LOCK:
+        record = _PTY_SESSIONS.pop(session_id, None)
+
+    if not record:
+        raise HTTPException(status_code=404, detail="PTY session not found")
+
+    bridge = record.get("bridge")
+    if bridge is not None:
+        try:
+            bridge.close()
+        except Exception:
+            _log.exception("Failed to close dashboard PTY session %s", session_id)
+            raise HTTPException(status_code=500, detail="Failed to close PTY session")
+
+    return {
+        "ok": True,
+        "id": session_id,
+        "profile": record.get("profile"),
+        "pid": record.get("pid"),
+    }
+
