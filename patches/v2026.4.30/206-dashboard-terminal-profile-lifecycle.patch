+function generateTerminalId(profileName: string): string {
+  const safeProfile = profileName.replace(/[^A-Za-z0-9._-]/g, "-").slice(0, 48) || "profile";
+  const suffix =
+    typeof crypto !== "undefined" && "randomUUID" in crypto
+      ? crypto.randomUUID().replace(/-/g, "").slice(0, 16)
+      : `${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 10)}`;
+  return `terminal-${safeProfile}-${suffix}`.slice(0, 128);
+}
+
 function profileChatHref(name: string): string {
-  const params = new URLSearchParams({ profile: name });
+  const params = new URLSearchParams();
+  params.set("profile", name);
+  params.set("terminal", generateTerminalId(name));
   return `/chat?${params.toString()}`;
