+    def test_close_pty_session_closes_bridge_and_removes_registry_entry(self):
+        from hermes_cli import web_server as ws
+
+        class _FakeBridge:
+            def __init__(self):
+                self.closed = False
+
+            def close(self):
+                self.closed = True
+
+        bridge = _FakeBridge()
+        with ws._PTY_SESSIONS_LOCK:
+            ws._PTY_SESSIONS.clear()
+            ws._PTY_SESSIONS["terminal-hermesfix-123"] = {
+                "id": "terminal-hermesfix-123",
+                "channel": "terminal-hermesfix-123",
+                "pid": 4321,
+                "profile": "hermesfix",
+                "bridge": bridge,
+            }
+
+        response = _client_with_dashboard_token().delete(
+            "/api/dashboard/runtimes/pty/terminal-hermesfix-123"
+        )
+
+        try:
+            assert response.status_code == 200
+            assert response.json() == {
+                "ok": True,
+                "id": "terminal-hermesfix-123",
+                "profile": "hermesfix",
+                "pid": 4321,
+            }
+            assert bridge.closed is True
+            with ws._PTY_SESSIONS_LOCK:
+                assert "terminal-hermesfix-123" not in ws._PTY_SESSIONS
+        finally:
+            with ws._PTY_SESSIONS_LOCK:
+                ws._PTY_SESSIONS.clear()
+
+    def test_close_pty_session_returns_404_for_unknown_session(self):
+        response = _client_with_dashboard_token().delete(
+            "/api/dashboard/runtimes/pty/missing-terminal"
+        )
+
+        assert response.status_code == 404
