+interface ChatTerminalTab {
+  id: string;
+  profile: string | null;
+  resume: string | null;
+  label: string;
+  createdAt: number;
+}
+
+const TERMINAL_ID_RE = /^[A-Za-z0-9._-]{1,128}$/;
+
+function sanitizeTerminalPart(value: string): string {
+  return value.replace(/[^A-Za-z0-9._-]/g, "-").slice(0, 48) || "terminal";
+}
+
+function generateDashboardTerminalId(profile: string | null): string {
+  const safeProfile = sanitizeTerminalPart(profile ?? "default");
+  const suffix =
+    typeof crypto !== "undefined" && "randomUUID" in crypto
+      ? crypto.randomUUID().replace(/-/g, "").slice(0, 16)
+      : `${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 10)}`;
+  return `terminal-${safeProfile}-${suffix}`.slice(0, 128);
+}
+
+function chatTerminalFromSearch(search: string, defaultTerminalId: string): ChatTerminalTab {
+  const params = new URLSearchParams(search);
+  const profile = params.get("profile");
+  const resume = params.get("resume");
+  const requestedId = params.get("terminal");
+  const isDefaultChat = !profile && !resume && !requestedId;
+  const id = isDefaultChat
+    ? defaultTerminalId
+    : requestedId && TERMINAL_ID_RE.test(requestedId)
+      ? requestedId
+      : generateDashboardTerminalId(profile);
+  const label = profile ?? "default";
+  return { id, profile, resume, label, createdAt: Date.now() };
+}
+
+function confirmDashboardTerminalClose(tab: ChatTerminalTab): boolean {
+  return window.confirm(
+    `Close terminal ${tab.label}? This will terminate the PTY process, not just hide the tab.`,
+  );
+}
+
+function TerminalWorkspaceTabs({
+  tabs,
+  activeId,
+  onSelect,
+  onClose,
+}: {
+  tabs: ChatTerminalTab[];
+  activeId: string | null;
+  onSelect: (id: string) => void;
+  onClose: (id: string) => void;
+}) {
+  if (tabs.length === 0) return null;
+  return (
+    <div
+      data-dashboard-terminal-tabs
+      className="mb-2 flex min-h-0 shrink-0 items-center gap-1 overflow-x-auto border border-current/15 bg-background-base/30 p-1"
+    >
+      {tabs.map((tab) => {
+        const active = tab.id === activeId;
+        return (
+          <div
+            key={tab.id}
+            className={cn(
+              "group flex max-w-[16rem] shrink-0 items-center gap-1 border px-2 py-1",
+              active
+                ? "border-primary/70 bg-primary/10 text-midground"
+                : "border-current/15 text-muted-foreground hover:text-midground",
+            )}
+            data-dashboard-terminal-tab={tab.id}
+          >
+            <button
+              type="button"
+              onClick={() => onSelect(tab.id)}
+              className="min-w-0 truncate text-left text-[0.7rem] tracking-[0.12em]"
+              title={`${tab.label} (${tab.id})`}
+            >
+              <span className="inline-flex items-center gap-1.5">
+                <Terminal className="h-3 w-3 shrink-0" />
+                <span className="truncate">{tab.label}</span>
+              </span>
+            </button>
+            <button
+              type="button"
+              aria-label={`Close terminal ${tab.label}`}
+              title="Close terminal"
+              onClick={() => onClose(tab.id)}
+              className="rounded-sm p-0.5 opacity-60 transition-opacity hover:bg-midground/10 hover:opacity-100"
+              data-close-dashboard-terminal-tab={tab.id}
+            >
+              <X className="h-3 w-3" />
+            </button>
+          </div>
+        );
+      })}
+    </div>
+  );
+}
+
+function EmptyTerminalWorkspace({ onOpenDefault }: { onOpenDefault: () => void }) {
+  return (
+    <div className="flex min-h-0 flex-1 items-center justify-center border border-current/15 bg-background-base/30 p-6">
+      <div className="max-w-md text-center">
+        <Terminal className="mx-auto mb-3 h-8 w-8 text-muted-foreground" />
+        <h3 className="font-expanded text-sm font-bold tracking-[0.12em] text-midground">No terminal open</h3>
+        <p className="mt-2 text-sm text-muted-foreground">
+          Open the default chat terminal or launch profile terminals from Profiles. Closing a tab terminates its PTY process.
+        </p>
+        <Button className="mt-4" onClick={onOpenDefault}>
+          Open default terminal
+        </Button>
+      </div>
+    </div>
+  );
+}
+
 export default function App() {
   const { t } = useI18n();
