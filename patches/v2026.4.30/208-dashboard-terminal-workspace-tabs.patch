+  const [activeChatTerminalId, setActiveChatTerminalId] = useState<string | null>(null);
+  const [defaultChatTerminalId] = useState(() => generateDashboardTerminalId(null));
 
   // A plugin can replace the built-in /chat page via `tab.override: "/chat"`
   // in its manifest.  When one does, `buildRoutes` already swaps the route
@@ -347,6 +471,57 @@ export default function App() {
     [manifests],
   );
 
+  useEffect(() => {
+    if (!embeddedChat || chatOverriddenByPlugin || !isChatRoute || pluginsLoading) return;
+    let cancelled = false;
+    void Promise.resolve().then(() => {
+      if (cancelled) return;
+      const tab = chatTerminalFromSearch(search, defaultChatTerminalId);
+      setChatTerminalTabs((current) => {
+        if (current.some((existing) => existing.id === tab.id)) return current;
+        return [...current, tab];
+      });
+      setActiveChatTerminalId(tab.id);
+    });
+    return () => {
+      cancelled = true;
+    };
+  }, [chatOverriddenByPlugin, defaultChatTerminalId, embeddedChat, isChatRoute, pluginsLoading, search]);
+
+  const openDefaultTerminal = useCallback(() => {
+    navigate("/chat");
+  }, [navigate]);
+
+  const selectDashboardTerminalTab = useCallback((id: string) => {
+    setActiveChatTerminalId(id);
+  }, []);
+
+  const closeDashboardTerminalTab = useCallback((id: string) => {
+    const tab = chatTerminalTabs.find((candidate) => candidate.id === id);
+    if (!tab) return;
+    if (!confirmDashboardTerminalClose(tab)) return;
+
+    const idx = chatTerminalTabs.findIndex((candidate) => candidate.id === id);
+    const remainingTabs = chatTerminalTabs.filter((candidate) => candidate.id !== id);
+    const selectedNextId =
+      activeChatTerminalId === id
+        ? remainingTabs[Math.min(idx, remainingTabs.length - 1)]?.id ?? null
+        : activeChatTerminalId;
+
+    const token = window.__HERMES_SESSION_TOKEN__;
+    if (token) {
+      fetch(`/api/dashboard/runtimes/pty/${encodeURIComponent(tab.id)}`, {
+        method: "DELETE",
+        headers: { "X-Hermes-Session-Token": token },
+      }).catch((err: unknown) => {
+        console.warn("[hermes-dashboard] close terminal tab request failed", err);
+      });
+    }
+
+    setChatTerminalTabs(remainingTabs);
+    setActiveChatTerminalId(selectedNextId);
+  }, [activeChatTerminalId, chatTerminalTabs]);
+
   const layoutVariant = theme.layoutVariant ?? "standard";
 
   useEffect(() => {
@@ -608,7 +783,41 @@ export default function App() {
                       )}
                       aria-hidden={!isChatRoute}
                     >
-                      <ChatPage isActive={isChatRoute} />
+                      <TerminalWorkspaceTabs
+                        tabs={chatTerminalTabs}
+                        activeId={activeChatTerminalId}
+                        onSelect={selectDashboardTerminalTab}
+                        onClose={closeDashboardTerminalTab}
+                      />
+                      {chatTerminalTabs.length === 0 ? (
+                        <EmptyTerminalWorkspace onOpenDefault={openDefaultTerminal} />
+                      ) : (
+                        <div className="min-h-0 min-w-0 flex flex-1 flex-col">
+                          {chatTerminalTabs.map((tab) => {
+                            const tabActive = tab.id === activeChatTerminalId;
+                            return (
+                              <div
+                                key={tab.id}
+                                data-dashboard-terminal-pane={tab.id}
+                                className={cn(
+                                  "min-h-0 min-w-0 flex-1 flex-col",
+                                  tabActive ? "flex" : "hidden",
+                                )}
+                                aria-hidden={!tabActive}
+                              >
+                                <ChatPage
+                                  isActive={isChatRoute && tabActive}
+                                  terminalId={tab.id}
+                                  profile={tab.profile}
+                                  resume={tab.resume}
+                                  terminalLabel={tab.label}
+                                  onRequestClose={() => closeDashboardTerminalTab(tab.id)}
+                                />
+                              </div>
+                            );
+                          })}
+                        </div>
+                      )}
                     </div>
                   ))}
               </div>
