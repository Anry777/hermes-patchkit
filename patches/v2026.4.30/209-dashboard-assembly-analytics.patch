+"""Tests for dashboard whole-assembly analytics endpoints."""
+
+from __future__ import annotations
+
+import os
+import time
+from pathlib import Path
+
+import pytest
+
+
+def _client_with_dashboard_token():
+    try:
+        from starlette.testclient import TestClient
+    except ImportError:  # pragma: no cover
+        pytest.skip("starlette TestClient not installed")
+
+    from hermes_cli import web_server
+
+    web_server._SESSION_TOKEN = "assembly-token"
+    web_server.app.state.session_token = "assembly-token"
+    return TestClient(web_server.app), web_server
+
+
+def _write_profile(home: Path, name: str, provider: str, model: str) -> Path:
+    profiles = home / "profiles"
+    profile_dir = profiles / name
+    profile_dir.mkdir(parents=True, exist_ok=True)
+    (profile_dir / "config.yaml").write_text(
+        f"default_provider: {provider}\ndefault_model: {model}\n",
+        encoding="utf-8",
+    )
+    return profile_dir
+
+
+def _seed_session(profile_dir: Path, session_id: str, *, last_active: float, provider: str, model: str, input_tokens: int, output_tokens: int) -> None:
+    from hermes_state import SessionDB
+
+    db = SessionDB(db_path=profile_dir / "state.db")
+    try:
+        db.create_session(
+            session_id=session_id,
+            source="cli",
+            model=model,
+        )
+        db.update_token_counts(
+            session_id,
+            input_tokens=input_tokens,
+            output_tokens=output_tokens,
+            model=model,
+            cache_read_tokens=11,
+            cache_write_tokens=7,
+            reasoning_tokens=5,
+            estimated_cost_usd=0.0123,
+            actual_cost_usd=0.0101,
+            billing_provider=provider,
+            api_call_count=3,
+            absolute=True,
+        )
+        with db._lock:
+            db._conn.execute(
+                """
+                UPDATE sessions
+                   SET started_at = ?,
+                       ended_at = ?,
+                       tool_call_count = ?
+                 WHERE id = ?
+                """,
+                (
+                    last_active - 30,
+                    last_active + 10,
+                    4,
+                    session_id,
+                ),
+            )
+    finally:
+        db.close()
+
+
+@pytest.fixture()
+def assembly_home(tmp_path, monkeypatch):
+    home = tmp_path / ".hermes"
+    home.mkdir()
+    monkeypatch.setattr(Path, "home", lambda: tmp_path)
+    monkeypatch.setenv("HERMES_HOME", str(home))
+    monkeypatch.setenv("HERMES_ACTIVE_PROFILE", "alpha")
+    (home / "config.yaml").write_text("active_profile: alpha\n", encoding="utf-8")
+    return home
+
+
+def test_dashboard_assembly_analytics_summarizes_profiles_without_session_content(assembly_home):
+    now = time.time()
+    alpha = _write_profile(assembly_home, "alpha", "openai", "gpt-5.4")
+    beta = _write_profile(assembly_home, "beta", "anthropic", "claude-sonnet-4")
+    _seed_session(
+        alpha,
+        "alpha-recent",
+        last_active=now - 60,
+        provider="openai",
+        model="gpt-5.4",
+        input_tokens=100,
+        output_tokens=50,
+    )
+    _seed_session(
+        beta,
+        "beta-old",
+        last_active=now - 60 * 60 * 24 * 90,
+        provider="anthropic",
+        model="claude-sonnet-4",
+        input_tokens=999,
+        output_tokens=999,
+    )
+
+    client, _web_server = _client_with_dashboard_token()
+    response = client.get(
+        "/api/dashboard/analytics/assembly?days=30",
+        headers={"X-Hermes-Session-Token": "assembly-token"},
+    )
+
+    assert response.status_code == 200
+    data = response.json()
+    assert data["period_days"] == 30
+    assert isinstance(data["active_profile"], str)
+    assert data["totals"]["profiles"] >= 2
+    assert data["totals"]["active_profiles"] >= 1
+    assert data["totals"]["stale_profiles"] >= 1
+    assert data["totals"]["total_sessions"] == 1
+    assert data["totals"]["input_tokens"] == 100
+    assert data["totals"]["output_tokens"] == 50
+    assert data["totals"]["api_calls"] == 3
+    assert data["totals"]["tool_calls"] == 4
+
+    profiles = {row["profile"]: row for row in data["profiles"]}
+    assert profiles["alpha"]["sessions"] == 1
+    assert profiles["alpha"]["provider"] == "openai"
+    assert profiles["alpha"]["model"] == "gpt-5.4"
+    assert profiles["alpha"]["stale"] is False
+    assert profiles["beta"]["sessions"] == 0
+    assert profiles["beta"]["stale"] is True
+    assert "beta" in data["stale_profiles"]
+    assert data["top_profiles_by_activity"][0]["profile"] == "alpha"
+    assert data["model_distribution"][0]["model"] == "gpt-5.4"
+    assert data["provider_distribution"][0]["provider"] == "openai"
+
+    serialized = str(data)
+    assert "alpha-recent" not in serialized
+    assert "beta-old" not in serialized
+    assert "messages" not in serialized
+
+
+def test_dashboard_assembly_analytics_validates_period(assembly_home):
+    _write_profile(assembly_home, "alpha", "openai", "gpt-5.4")
+    client, _web_server = _client_with_dashboard_token()
+
+    response = client.get(
+        "/api/dashboard/analytics/assembly?days=0",
+        headers={"X-Hermes-Session-Token": "assembly-token"},
+    )
+
+    assert response.status_code == 400
+    assert "days" in response.json()["detail"]
+
+
+def test_dashboard_assembly_analytics_requires_dashboard_token(assembly_home):
+    _write_profile(assembly_home, "alpha", "openai", "gpt-5.4")
+    client, _web_server = _client_with_dashboard_token()
+
+    response = client.get("/api/dashboard/analytics/assembly?days=30")
+
+    assert response.status_code == 401
