     return {"total": summary["total"], "active": active, "recent": summary["sessions"]}
 
 
+def _empty_dashboard_profile_analytics(profile: str, provider: Optional[str] = None, model: Optional[str] = None) -> Dict[str, Any]:
+    return {
+        "profile": profile,
+        "provider": provider,
+        "model": model,
+        "sessions": 0,
+        "active_sessions": 0,
+        "input_tokens": 0,
+        "output_tokens": 0,
+        "cache_read_tokens": 0,
+        "cache_write_tokens": 0,
+        "reasoning_tokens": 0,
+        "estimated_cost_usd": 0.0,
+        "actual_cost_usd": 0.0,
+        "api_calls": 0,
+        "tool_calls": 0,
+        "last_active": None,
+        "stale": True,
+    }
+
+
+def _profile_analytics_snapshot(
+    profile: str,
+    profile_dir: Path,
+    *,
+    cutoff: float,
+    now: float,
+    provider: Optional[str] = None,
+    model: Optional[str] = None,
+) -> Dict[str, Any]:
+    """Summarize safe profile activity metadata for the assembly dashboard."""
+    db_path = profile_dir / "state.db"
+    summary = _empty_dashboard_profile_analytics(profile, provider=provider, model=model)
+    if not db_path.exists():
+        return summary
+
+    from hermes_state import SessionDB
+
+    db = SessionDB(db_path=db_path)
+    try:
+        total = db.session_count()
+        sessions = db.list_sessions_rich(
+            limit=max(total, 1),
+            offset=0,
+            include_children=True,
+            project_compression_tips=False,
+        )
+    finally:
+        db.close()
+
+    active_rows = []
+    for row in sessions:
+        started_at = row.get("started_at") or 0
+        last_active = row.get("last_active") or started_at
+        if last_active < cutoff and started_at < cutoff:
+            continue
+        active_rows.append(row)
+
+    for row in active_rows:
+        started_at = row.get("started_at") or 0
+        last_active = row.get("last_active") or started_at
+        summary["sessions"] += 1
+        summary["input_tokens"] += int(row.get("input_tokens") or 0)
+        summary["output_tokens"] += int(row.get("output_tokens") or 0)
+        summary["cache_read_tokens"] += int(row.get("cache_read_tokens") or 0)
+        summary["cache_write_tokens"] += int(row.get("cache_write_tokens") or 0)
+        summary["reasoning_tokens"] += int(row.get("reasoning_tokens") or 0)
+        summary["estimated_cost_usd"] += float(row.get("estimated_cost_usd") or 0)
+        summary["actual_cost_usd"] += float(row.get("actual_cost_usd") or 0)
+        summary["api_calls"] += int(row.get("api_call_count") or 0)
+        summary["tool_calls"] += int(row.get("tool_call_count") or 0)
+        if row.get("ended_at") is None and (now - last_active) < 300:
+            summary["active_sessions"] += 1
+        if summary["last_active"] is None or last_active > summary["last_active"]:
+            summary["last_active"] = last_active
+        if not summary.get("model") and row.get("model"):
+            summary["model"] = row.get("model")
+        if not summary.get("provider") and row.get("billing_provider"):
+            summary["provider"] = row.get("billing_provider")
+
+    summary["estimated_cost_usd"] = round(summary["estimated_cost_usd"], 8)
+    summary["actual_cost_usd"] = round(summary["actual_cost_usd"], 8)
+    summary["stale"] = not active_rows
+    return summary
+
+
+def _aggregate_distribution(items: List[Dict[str, Any]], key: str) -> List[Dict[str, Any]]:
+    buckets: Dict[str, Dict[str, Any]] = {}
+    for item in items:
+        name = str(item.get(key) or "unknown")
+        bucket = buckets.setdefault(name, {
+            key: name,
+            "sessions": 0,
+            "input_tokens": 0,
+            "output_tokens": 0,
+            "estimated_cost_usd": 0.0,
+            "api_calls": 0,
+        })
+        bucket["sessions"] += int(item.get("sessions") or 0)
+        bucket["input_tokens"] += int(item.get("input_tokens") or 0)
+        bucket["output_tokens"] += int(item.get("output_tokens") or 0)
+        bucket["estimated_cost_usd"] += float(item.get("estimated_cost_usd") or 0)
+        bucket["api_calls"] += int(item.get("api_calls") or 0)
+    for bucket in buckets.values():
+        bucket["estimated_cost_usd"] = round(bucket["estimated_cost_usd"], 8)
+    return sorted(
+        buckets.values(),
+        key=lambda item: (
+            int(item.get("sessions") or 0),
+            int(item.get("input_tokens") or 0) + int(item.get("output_tokens") or 0),
+            str(item.get(key) or ""),
+        ),
+        reverse=True,
+    )
+
+
+def _serialize_dashboard_assembly_analytics(days: int) -> Dict[str, Any]:
+    """Return safe per-profile and whole-assembly usage/activity analytics."""
+    from hermes_cli.profiles import get_active_profile, get_profile_dir, list_profiles
+
+    now = time.time()
+    cutoff = now - (days * 86400)
+    active_profile = get_active_profile()
+    profiles = list_profiles()
+    profile_rows: List[Dict[str, Any]] = []
+    errors: List[Dict[str, str]] = []
+
+    for profile in profiles:
+        try:
+            row = _profile_analytics_snapshot(
+                profile.name,
+                get_profile_dir(profile.name),
+                cutoff=cutoff,
+                now=now,
+                provider=profile.provider,
+                model=profile.model,
+            )
+        except Exception:
+            _log.exception("Failed to build dashboard analytics for profile %s", profile.name)
+            row = _empty_dashboard_profile_analytics(
+                profile.name,
+                provider=getattr(profile, "provider", None),
+                model=getattr(profile, "model", None),
+            )
+            row["error"] = "analytics unavailable"
+            errors.append({"profile": profile.name, "error": "analytics unavailable"})
+        profile_rows.append(row)
+
+    totals = {
+        "profiles": len(profile_rows),
+        "active_profiles": sum(1 for row in profile_rows if not row.get("stale")),
+        "stale_profiles": sum(1 for row in profile_rows if row.get("stale")),
+        "active_sessions": sum(int(row.get("active_sessions") or 0) for row in profile_rows),
+        "total_sessions": sum(int(row.get("sessions") or 0) for row in profile_rows),
+        "input_tokens": sum(int(row.get("input_tokens") or 0) for row in profile_rows),
+        "output_tokens": sum(int(row.get("output_tokens") or 0) for row in profile_rows),
+        "cache_read_tokens": sum(int(row.get("cache_read_tokens") or 0) for row in profile_rows),
+        "cache_write_tokens": sum(int(row.get("cache_write_tokens") or 0) for row in profile_rows),
+        "reasoning_tokens": sum(int(row.get("reasoning_tokens") or 0) for row in profile_rows),
+        "estimated_cost_usd": round(sum(float(row.get("estimated_cost_usd") or 0) for row in profile_rows), 8),
+        "actual_cost_usd": round(sum(float(row.get("actual_cost_usd") or 0) for row in profile_rows), 8),
+        "api_calls": sum(int(row.get("api_calls") or 0) for row in profile_rows),
+        "tool_calls": sum(int(row.get("tool_calls") or 0) for row in profile_rows),
+    }
+
+    return {
+        "period_days": days,
+        "generated_at": now,
+        "active_profile": active_profile,
+        "totals": totals,
+        "profiles": sorted(profile_rows, key=lambda row: str(row.get("profile") or "")),
+        "top_profiles_by_activity": sorted(
+            profile_rows,
+            key=lambda row: (
+                int(row.get("sessions") or 0),
+                int(row.get("api_calls") or 0),
+                int(row.get("input_tokens") or 0) + int(row.get("output_tokens") or 0),
+                str(row.get("profile") or ""),
+            ),
+            reverse=True,
+        )[:10],
+        "stale_profiles": [str(row.get("profile")) for row in profile_rows if row.get("stale")],
+        "model_distribution": _aggregate_distribution(profile_rows, "model"),
+        "provider_distribution": _aggregate_distribution(profile_rows, "provider"),
+        "errors": errors,
+    }
+
+
+@app.get("/api/dashboard/analytics/assembly")
+async def get_dashboard_assembly_analytics(days: int = 30):
+    """Return safe aggregate analytics across all Hermes profiles."""
+    if days < 1 or days > 3650:
+        raise HTTPException(status_code=400, detail="days must be between 1 and 3650")
+    try:
+        return _serialize_dashboard_assembly_analytics(days)
+    except HTTPException:
+        raise
+    except Exception:
+        _log.exception("GET /api/dashboard/analytics/assembly failed")
+        raise HTTPException(status_code=500, detail="Internal server error")
+
+
 def _dashboard_pty_sessions_snapshot() -> List[Dict[str, Any]]:
     """Return a sanitized snapshot of active dashboard PTY sessions."""
     with _PTY_SESSIONS_LOCK:
