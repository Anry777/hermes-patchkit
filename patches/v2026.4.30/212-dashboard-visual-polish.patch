   display: none;
 }
 
+/* Dashboard visual polish primitives.  These are intentionally semantic
+   classes used by control-plane pages after 211 so visual refinement does not
+   reintroduce per-page one-off spacing and contrast decisions. */
+.dashboard-content-shell {
+  width: 100%;
+  max-width: min(100%, 1680px);
+  margin-inline: auto;
+}
+
+.dashboard-overview-hero {
+  border: 1px solid color-mix(in srgb, var(--midground-base) 16%, transparent);
+  background:
+    radial-gradient(circle at 0% 0%, color-mix(in srgb, var(--warm-glow) 24%, transparent), transparent 34rem),
+    linear-gradient(135deg,
+      color-mix(in srgb, var(--midground-base) 7%, var(--background-base)) 0%,
+      color-mix(in srgb, var(--midground-base) 2%, var(--background-base)) 100%);
+  box-shadow:
+    inset 0 1px 0 color-mix(in srgb, var(--midground-base) 12%, transparent),
+    0 24px 70px rgba(0, 0, 0, 0.22);
+  backdrop-filter: blur(12px);
+}
+
+.dashboard-panel-card {
+  border-color: color-mix(in srgb, var(--midground-base) 18%, transparent);
+  background:
+    linear-gradient(180deg,
+      color-mix(in srgb, var(--midground-base) 5.5%, var(--background-base)) 0%,
+      color-mix(in srgb, var(--midground-base) 2.5%, var(--background-base)) 100%);
+  box-shadow:
+    inset 0 1px 0 color-mix(in srgb, var(--midground-base) 9%, transparent),
+    0 16px 45px rgba(0, 0, 0, 0.18);
+  backdrop-filter: blur(10px);
+}
+
+.dashboard-metric-grid,
+.dashboard-panel-grid {
+  gap: clamp(0.9rem, 1.25vw, 1.35rem);
+}
+
+.dashboard-metric-card {
+  min-height: 8.25rem;
+}
+.dashboard-metric-card svg {
+  margin-top: 0.2rem;
+  color: color-mix(in srgb, var(--midground-base) 68%, transparent);
+}
+.dashboard-metric-label {
+  color: color-mix(in srgb, var(--midground-base) 68%, transparent);
+  letter-spacing: 0.1em;
+}
+.dashboard-metric-detail {
+  color: color-mix(in srgb, var(--midground-base) 62%, transparent);
+}
+
+.dashboard-density-table {
+  border-collapse: separate;
+  border-spacing: 0;
+}
+.dashboard-density-table th {
+  padding-block: 0.72rem;
+  color: color-mix(in srgb, var(--midground-base) 62%, transparent);
+  letter-spacing: 0.1em;
+}
+.dashboard-density-table td {
+  padding-block: 0.78rem;
+  line-height: 1.45;
+}
+.dashboard-density-table tbody tr:first-child td {
+  border-top-width: 1px;
+}
+.dashboard-density-table tbody tr:hover td {
+  background: color-mix(in srgb, var(--midground-base) 3.5%, transparent);
+}
+
+.dashboard-row-card {
+  border-color: color-mix(in srgb, var(--midground-base) 15%, transparent);
+  background: color-mix(in srgb, var(--midground-base) 3.2%, transparent);
+  box-shadow: inset 0 1px 0 color-mix(in srgb, var(--midground-base) 6%, transparent);
+}
+.dashboard-row-card:hover {
+  border-color: color-mix(in srgb, var(--midground-base) 24%, transparent);
+  background: color-mix(in srgb, var(--midground-base) 4.6%, transparent);
+}
+
+.dashboard-sidebar-status {
+  border: 1px solid color-mix(in srgb, var(--midground-base) 12%, transparent);
+  background: color-mix(in srgb, var(--midground-base) 3.8%, transparent);
+  box-shadow: inset 0 1px 0 color-mix(in srgb, var(--midground-base) 7%, transparent);
+}
+
+@media (min-width: 1280px) {
+  .dashboard-content-shell {
+    max-width: min(100%, 1720px);
+  }
+}
