+    assert "dashboard-overview-hero" in overview
+    assert "dashboard-metric-grid" in overview
+    assert "dashboard-metric-card" in overview
+    assert "dashboard-panel-grid" in overview
+    assert "dashboard-density-table" in overview
+    assert "dashboard-row-card" in overview
+    assert "Polished operator overview" in overview
