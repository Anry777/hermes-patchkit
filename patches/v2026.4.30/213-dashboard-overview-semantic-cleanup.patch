+def _dashboard_provider_proxy_evidence(profile: str) -> Dict[str, Any]:
+    """Return best-effort service/API evidence for a provider-proxy profile.
+
+    Keep this metadata-only: probe a public health/model endpoint and process
+    command lines, never env values, logs, request bodies, or auth material.
+    """
+    if profile != "provider-proxy":
+        return {}
+
+    url = (
+        os.getenv("HERMES_PROVIDER_PROXY_HEALTH_URL")
+        or os.getenv("PROVIDER_PROXY_HEALTH_URL")
+        or "http://127.0.0.1:8642/v1/models"
+    )
+    try:
+        req = urllib.request.Request(url, method="GET")
+        with urllib.request.urlopen(req, timeout=0.5) as resp:
+            if 200 <= resp.status < 300:
+                return {
+                    "state": "running",
+                    "source": "api probe",
+                    "message": "provider_proxy API is reachable",
+                }
+    except Exception:
+        pass
+
+    proc_root = Path("/proc")
+    try:
+        for cmdline_path in proc_root.glob("[0-9]*/cmdline"):
+            try:
+                cmdline = cmdline_path.read_bytes().replace(b"\x00", b" ").decode("utf-8", "replace")
+            except OSError:
+                continue
+            lower = cmdline.lower()
+            if "provider-proxy" in lower or "provider_proxy" in lower:
+                return {
+                    "state": "running",
+                    "source": "process list",
+                    "message": "provider_proxy process is present",
+                }
+    except Exception:
+        pass
+
+    return {
+        "state": "unknown",
+        "source": "service probe",
+        "message": "provider_proxy service evidence unavailable",
+    }
+
+
+def _dashboard_runtime_health(
+    profile_rows: List[Dict[str, Any]],
+    pty_sessions: List[Dict[str, Any]],
+    now: float,
+) -> List[Dict[str, Any]]:
+    rows: List[Dict[str, Any]] = []
+    pty_profiles = {str(session.get("profile") or "default") for session in pty_sessions}
+
+    for profile_row in profile_rows:
+        profile = str(profile_row.get("profile") or "")
+        if profile != "provider-proxy":
+            continue
+        evidence = _dashboard_provider_proxy_evidence(profile)
+        state = str(evidence.get("state") or "unknown")
+        reason = str(evidence.get("message") or "provider_proxy service evidence unavailable")
+        rows.append({
+            "id": profile,
+            "component": "provider_proxy",
+            "profile": profile,
+            "kind": "service_api",
+            "state": state,
+            "healthy": state in {"running", "ok", "connected"},
+            "source": str(evidence.get("source") or "service probe"),
+            "reason": reason,
+            "message": reason,
+            "profile_stale": bool(profile_row.get("stale")),
+            "has_live_terminal": profile in pty_profiles,
+            "checked_at": datetime.fromtimestamp(now, timezone.utc).isoformat(),
+            "route": f"/profiles?profile={urllib.parse.quote(profile)}",
+        })
+    return rows
+
+
+def _dashboard_attention_items(
+    platform_rows: List[Dict[str, Any]],
+    runtime_health: List[Dict[str, Any]],
+) -> List[Dict[str, Any]]:
+    items: List[Dict[str, Any]] = []
+    for row in platform_rows:
+        reason = row.get("attention_reason")
+        if not row.get("needs_attention") or not reason:
+            continue
+        name = str(row.get("name") or "unknown")
+        items.append({
+            "id": f"gateway-platform:{name}",
+            "source": "gateway",
+            "severity": row.get("attention_severity") or "warning",
+            "reason": reason,
+            "message": f"{name} gateway platform: {reason}",
+            "action": row.get("attention_action") or "Open gateway status",
+            "target_kind": "gateway_platform",
+            "target_id": name,
+            "route": "/platforms",
+        })
+
+    for row in runtime_health:
+        if row.get("healthy") or row.get("state") == "unknown":
+            continue
+        profile = str(row.get("profile") or row.get("id") or "runtime")
+        reason = str(row.get("reason") or "Runtime component is not healthy")
+        items.append({
+            "id": f"runtime:{profile}",
+            "source": "runtime",
+            "severity": "warning",
+            "reason": reason,
+            "message": f"{profile}: {reason}",
+            "action": "Open runtime details",
+            "target_kind": "runtime_health",
+            "target_id": profile,
+            "route": row.get("route") or "/overview",
+        })
+    return items
+
+
 def _serialize_dashboard_overview() -> Dict[str, Any]:
     """Unified read-only dashboard control-plane summary.
 
@@ -994,12 +1135,25 @@ def _serialize_dashboard_overview() -> Dict[str, Any]:
