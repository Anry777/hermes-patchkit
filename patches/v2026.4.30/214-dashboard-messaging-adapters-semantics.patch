+++ b/tests/hermes_cli/test_dashboard_profile_selector_frontend.py
@@ -191,10 +191,19 @@ def test_overview_semantic_cleanup_contract():
     assert "selected_profile" in api
     assert "runtime_health" in api
     assert "attention_items" in api
+    assert "messaging_adapters" in api
+    assert "adapter_rows" in api
+    assert "event_freshness" in api
+    assert "action_required" in api
     assert "new Intl.NumberFormat(\"en-US\"" in overview
-    assert "Hermes control plane for profiles, terminals, gateway platforms, and runtime health." in overview
+    assert "Hermes control plane for profiles, terminals, messaging adapters, and runtime health." in overview
     assert "Assembly overview" in overview
     assert "Selected profile" in overview
+    assert "Messaging adapters" in overview
+    assert "Adapter freshness" in overview
+    assert "Check freshness" in overview
+    assert "gateway platforms" not in overview
+    assert "Gateway platforms" not in overview
     assert "provider-proxy" in overview
     assert "ACTION REQUIRED" in sidebar
     assert "attention_items.length" in sidebar
diff --git a/tests/hermes_cli/test_web_server_dashboard_overview.py b/tests/hermes_cli/test_web_server_dashboard_overview.py
index b02a5676e..91bf7a3fc 100644
--- a/tests/hermes_cli/test_web_server_dashboard_overview.py
+++ b/tests/hermes_cli/test_web_server_dashboard_overview.py
@@ -70,7 +70,8 @@ def test_dashboard_overview_unifies_counts_and_safe_terms(tmp_path, monkeypatch)
         "updated_at": "2026-05-03T10:00:00+00:00",
         "platforms": {
             "telegram": {"state": "connected", "updated_at": "2026-05-01T10:00:00+00:00"},
-            "discord": {"state": "disconnected", "updated_at": "2026-05-03T09:00:00+00:00"},
+            "discord": {"state": "disconnected", "updated_at": "2026-05-04T18:00:00+00:00"},
+            "api_server": {"state": "connected", "updated_at": "2026-05-01T09:00:00+00:00"},
         },
     })
     monkeypatch.setattr(ws, "_dashboard_provider_proxy_evidence", lambda profile: {
@@ -104,8 +105,27 @@ def test_dashboard_overview_unifies_counts_and_safe_terms(tmp_path, monkeypatch)
     assert data["sessions"]["current_profile_total"] >= 1
     assert data["terminals"]["active"] == 1
     assert data["gateway"]["running"] is True
-    assert data["gateway"]["platforms"]["connected"] == 1
-    assert data["gateway"]["platforms"]["attention"] >= 1
+    assert data["gateway"]["platforms"]["connected"] == 2
+    assert data["gateway"]["platforms"]["stale"] == 2
+    assert data["gateway"]["platforms"]["attention"] == 1
+    assert data["gateway"]["messaging_adapters"]["connected"] == 2
+    assert data["gateway"]["messaging_adapters"]["action_required"] == 1
+    assert data["gateway"]["messaging_adapters"]["check_freshness"] == 2
+
+    api_server = next(row for row in data["gateway"]["adapter_rows"] if row["name"] == "api_server")
+    assert api_server["kind"] == "messaging_adapter"
+    assert api_server["availability"] == "available"
+    assert api_server["event_freshness"] == "stale"
+    assert api_server["needs_attention"] is False
+    assert api_server["action_required"] is False
+    assert api_server["attention_reason"] is None
+    assert api_server["freshness_reason"] == "No adapter event for more than 24 hours"
+
+    discord = next(row for row in data["gateway"]["adapter_rows"] if row["name"] == "discord")
+    assert discord["availability"] == "disconnected"
+    assert discord["action_required"] is True
+    assert discord["attention_reason"] == "Messaging adapter state is disconnected"
+    assert {item["target_id"] for item in data["attention_items"]} == {"discord"}
 
     provider_proxy_health = next(
         item for item in data["runtime_health"] if item["id"] == "provider-proxy"
