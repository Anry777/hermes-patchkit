From: Anry777 <Anry777@users.noreply.github.com>
Date: Mon, 4 May 2026 22:03:31 +0300
Subject: [PATCH] feat: clarify dashboard messaging adapter semantics

---
 hermes_cli/web_server.py                      | 55 +++++++++++++------
 ...est_dashboard_profile_selector_frontend.py | 11 +++-
 .../test_web_server_dashboard_overview.py     | 26 ++++++++-
 web/src/lib/api.ts                            | 13 +++++
 web/src/pages/OverviewPage.tsx                | 28 +++++-----
 5 files changed, 98 insertions(+), 35 deletions(-)

diff --git a/hermes_cli/web_server.py b/hermes_cli/web_server.py
index 27f27d3cc..a45d0ae22 100644
--- a/hermes_cli/web_server.py
+++ b/hermes_cli/web_server.py
@@ -938,6 +938,7 @@ def _dashboard_platform_rows(runtime: Optional[Dict[str, Any]], now: float) -> L
     rows: List[Dict[str, Any]] = []
     stale_after_seconds = 24 * 3600
     healthy_states = {"connected", "running", "ok"}
+    warning_states = {"disconnected", "unknown", "stopped"}
     for name, raw in sorted(platforms.items()):
         info = raw if isinstance(raw, dict) else {}
         state = str(info.get("state") or "unknown")
@@ -945,26 +946,36 @@ def _dashboard_platform_rows(runtime: Optional[Dict[str, Any]], now: float) -> L
         updated_ts = _parse_dashboard_iso_timestamp(updated_at)
         age_seconds = None if updated_ts is None else max(0, int(now - updated_ts))
         stale = age_seconds is not None and age_seconds > stale_after_seconds
-        needs_attention = state not in healthy_states or stale
-        display_state = "STALE" if state == "connected" and stale else state.upper()
+        healthy = state in healthy_states
+        action_required = not healthy
+        availability = "available" if healthy else state
+        event_freshness = "unknown" if age_seconds is None else ("stale" if stale else "fresh")
+        display_state = "CONNECTED" if healthy else state.upper()
+
+        freshness_reason = None
+        if event_freshness == "stale":
+            freshness_reason = "No adapter event for more than 24 hours"
+        elif event_freshness == "unknown":
+            freshness_reason = "No adapter heartbeat timestamp reported"
 
         attention_reason = None
         attention_severity = None
         attention_action = None
-        if state not in healthy_states:
-            attention_reason = f"Gateway platform state is {state}"
-            attention_severity = "warning" if state in {"disconnected", "unknown", "stopped"} else "error"
-            attention_action = "Open gateway status and platform logs"
-        elif stale:
-            attention_reason = "No gateway platform heartbeat for more than 24 hours"
-            attention_severity = "info"
-            attention_action = "Check gateway freshness before taking action"
+        if action_required:
+            attention_reason = f"Messaging adapter state is {state}"
+            attention_severity = "warning" if state in warning_states else "error"
+            attention_action = "Open gateway status and adapter logs"
 
         rows.append({
             "name": str(name),
+            "kind": "messaging_adapter",
             "state": state,
+            "availability": availability,
+            "event_freshness": event_freshness,
+            "freshness_reason": freshness_reason,
             "display_state": display_state,
-            "needs_attention": needs_attention,
+            "needs_attention": action_required,
+            "action_required": action_required,
             "attention_reason": attention_reason,
             "attention_severity": attention_severity,
             "attention_action": attention_action,
@@ -1070,13 +1081,13 @@ def _dashboard_attention_items(
             continue
         name = str(row.get("name") or "unknown")
         items.append({
-            "id": f"gateway-platform:{name}",
-            "source": "gateway",
+            "id": f"messaging-adapter:{name}",
+            "source": "messaging_adapter",
             "severity": row.get("attention_severity") or "warning",
             "reason": reason,
-            "message": f"{name} gateway platform: {reason}",
+            "message": f"{name} messaging adapter: {reason}",
             "action": row.get("attention_action") or "Open gateway status",
-            "target_kind": "gateway_platform",
+            "target_kind": "messaging_adapter",
             "target_id": name,
             "route": "/platforms",
         })
@@ -1135,6 +1146,7 @@ def _serialize_dashboard_overview() -> Dict[str, Any]:
         if not gateway_running:
             gateway_state = gateway_state if gateway_state in ("stopped", "startup_failed") else "stopped"
     platform_rows = _dashboard_platform_rows(runtime_status, now) if gateway_running else []
+    adapter_rows = platform_rows
     runtime_health = _dashboard_runtime_health(profile_rows, pty_sessions, now)
     attention_items = _dashboard_attention_items(platform_rows, runtime_health)
     selected_profile = {
@@ -1183,9 +1195,17 @@ def _serialize_dashboard_overview() -> Dict[str, Any]:
             "platforms": {
                 "total": len(platform_rows),
                 "connected": sum(1 for row in platform_rows if row.get("state") == "connected"),
-                "stale": sum(1 for row in platform_rows if row.get("display_state") == "STALE"),
+                "stale": sum(1 for row in platform_rows if row.get("event_freshness") == "stale"),
                 "attention": sum(1 for row in platform_rows if row.get("needs_attention")),
             },
+            "messaging_adapters": {
+                "total": len(adapter_rows),
+                "connected": sum(1 for row in adapter_rows if row.get("availability") == "available"),
+                "disconnected": sum(1 for row in adapter_rows if row.get("availability") == "disconnected"),
+                "check_freshness": sum(1 for row in adapter_rows if row.get("event_freshness") == "stale"),
+                "action_required": sum(1 for row in adapter_rows if row.get("action_required")),
+            },
+            "adapter_rows": adapter_rows,
             "platform_rows": platform_rows,
         },
         "runtime": {
@@ -1201,7 +1221,8 @@ def _serialize_dashboard_overview() -> Dict[str, Any]:
             "historical_sessions": "session DB records across profiles",
             "recently_active_db_records": "unended session DB records active in the last five minutes",
             "active_terminals": "live dashboard PTY channels",
-            "connected_platforms": "gateway platform adapters currently reporting connected",
+            "connected_platforms": "backward-compatible count of gateway messaging adapters reporting connected",
+            "messaging_adapters": "gateway adapter availability; stale event freshness is metadata, not action by itself",
             "action_required": "items with explicit reason, source, severity, message, and action",
             "runtime_health": "service or API health evidence for dashboard-managed components",
         },
diff --git a/tests/hermes_cli/test_dashboard_profile_selector_frontend.py b/tests/hermes_cli/test_dashboard_profile_selector_frontend.py
index c77e9977e..6205ddb3a 100644
