diff --git a/web/src/pages/OverviewPage.tsx b/web/src/pages/OverviewPage.tsx
index b59543fdd..32b35bd54 100644
--- a/web/src/pages/OverviewPage.tsx
+++ b/web/src/pages/OverviewPage.tsx
@@ -22,10 +22,10 @@ function fmt(n: number): string {
   return (n >= 1_000_000 ? compactFormatter : standardFormatter).format(n);
 }
 
-function platformTone(state: string): "success" | "warning" | "destructive" | "outline" {
-  const normalized = state.toLowerCase();
-  if (normalized === "connected") return "success";
-  if (normalized === "stale" || normalized === "disconnected") return "warning";
+function platformTone(platform: { availability: string; action_required: boolean }): "success" | "warning" | "destructive" | "outline" {
+  const normalized = platform.availability.toLowerCase();
+  if (!platform.action_required && normalized === "available") return "success";
+  if (normalized === "disconnected" || normalized === "unknown" || normalized === "stopped") return "warning";
   if (normalized === "fatal" || normalized === "error") return "destructive";
   return "outline";
 }
@@ -84,7 +84,7 @@ export default function OverviewPage() {
             Hermes control plane
           </h2>
           <p className="mt-2 max-w-2xl text-sm leading-6 text-muted-foreground/85">
-            Hermes control plane for profiles, terminals, gateway platforms, and runtime health.
+            Hermes control plane for profiles, terminals, messaging adapters, and runtime health.
           </p>
           <p className="mt-3 text-xs text-muted-foreground">
             Selected profile: <span className="font-medium text-foreground">{selectedProfileName}</span>
@@ -108,7 +108,7 @@ export default function OverviewPage() {
             <MetricCard icon={Database} label="Historical sessions" value={fmt(overview.sessions.total)} detail={`${fmt(overview.sessions.current_profile_total)} in selected profile`} />
             <MetricCard icon={Terminal} label="Active terminals" value={fmt(overview.terminals.active)} detail="Live dashboard PTY channels" />
             <MetricCard icon={Users} label="Profiles" value={`${overview.profiles.active}/${overview.profiles.total}`} detail={`${overview.profiles.stale} with no recent session activity`} />
-            <MetricCard icon={Radio} label="Gateway platforms" value={`${overview.gateway.platforms.connected}/${overview.gateway.platforms.total}`} detail={actionRequired > 0 ? `${fmt(actionRequired)} Action required` : "No action required"} />
+            <MetricCard icon={Radio} label="Messaging adapters" value={`${overview.gateway.messaging_adapters.connected}/${overview.gateway.messaging_adapters.total}`} detail={actionRequired > 0 ? `${fmt(actionRequired)} Action required` : `${fmt(overview.gateway.messaging_adapters.check_freshness)} Check freshness`} />
           </div>
 
           <div className="dashboard-panel-grid grid xl:grid-cols-[1.35fr_0.9fr]">
@@ -200,23 +200,23 @@ export default function OverviewPage() {
 
               <Card>
                 <CardHeader>
-                  <CardTitle className="text-base">Platform freshness</CardTitle>
+                  <CardTitle className="text-base">Adapter freshness</CardTitle>
                 </CardHeader>
                 <CardContent className="grid gap-3">
-                  {overview.gateway.platform_rows.length === 0 ? (
-                    <p className="text-sm text-muted-foreground">No gateway platforms reported.</p>
+                  {overview.gateway.adapter_rows.length === 0 ? (
+                    <p className="text-sm text-muted-foreground">No messaging adapters reported.</p>
                   ) : (
-                    overview.gateway.platform_rows.map((platform) => (
+                    overview.gateway.adapter_rows.map((platform) => (
                       <div key={platform.name} className="dashboard-row-card flex items-center justify-between gap-4 border p-3.5 transition-colors">
                         <div className="min-w-0">
                           <p className="truncate text-sm font-medium capitalize">{platform.name}</p>
                           <p className="text-xs text-muted-foreground">
-                            {platform.attention_reason ?? (platform.updated_at ? `Last event ${isoTimeAgo(platform.updated_at)}` : "No heartbeat")}
+                            {platform.attention_reason ?? platform.freshness_reason ?? (platform.updated_at ? `Last event ${isoTimeAgo(platform.updated_at)}` : "No adapter heartbeat")}
                           </p>
                         </div>
-                        <Badge tone={platformTone(platform.display_state)} className="text-[10px] shrink-0">
-                          {platform.needs_attention && <AlertTriangle className="mr-1 h-3 w-3" />}
-                          {platform.display_state}
+                        <Badge tone={platformTone(platform)} className="text-[10px] shrink-0">
+                          {platform.action_required && <AlertTriangle className="mr-1 h-3 w-3" />}
+                          {platform.action_required ? platform.display_state : platform.event_freshness}
                         </Badge>
                       </div>
                     ))
