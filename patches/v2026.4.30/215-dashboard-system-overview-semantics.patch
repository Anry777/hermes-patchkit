+function memoryUsageLabel(row: DashboardOverviewResponse["memory"]["rows"][number]): string {
+  if (!row.enabled) return "disabled";
+  if (typeof row.external?.record_count === "number") return "tracked";
+  if (typeof row.usage_percent === "number") return `${row.usage_percent}% used`;
+  if (row.usage_state === "unknown") return "usage unknown";
+  if (row.usage_state === "partial") return "partial usage";
+  return row.usage_state;
+}
+
+function memoryRowDetail(row: DashboardOverviewResponse["memory"]["rows"][number]): string {
+  const localRecords = row.local_record_count ?? row.builtin?.record_count ?? 0;
+  const external = row.external;
+  if (!external) return `${fmt(localRecords)} local records · local files`;
+  const bank = external.bank_id ? `bank ${external.bank_id}` : external.mode;
+  const externalCount = typeof external.record_count === "number"
+    ? `${fmt(external.record_count)} memories`
+    : "external count unavailable";
+  return `${fmt(localRecords)} local records · ${external.provider} ${bank} · ${externalCount}`;
+}
+
+function providerList(overview: DashboardOverviewResponse): string {
+  const providers = overview.memory.providers.map((provider) => provider.provider);
+  if (providers.length === 0) return "No memory providers enabled";
+  return providers.join(", ");
+}
