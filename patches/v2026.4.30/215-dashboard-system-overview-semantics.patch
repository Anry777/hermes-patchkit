+def _read_dashboard_profile_config(profile_dir: Path) -> Dict[str, Any]:
+    """Read profile config.yaml for safe dashboard metadata."""
+    config_path = profile_dir / "config.yaml"
+    if not config_path.exists():
+        return {}
+    try:
+        raw = yaml.safe_load(config_path.read_text(encoding="utf-8")) or {}
+    except Exception:
+        _log.exception("Failed to read dashboard profile config for %s", profile_dir)
+        return {}
+    return raw if isinstance(raw, dict) else {}
+
+
+def _safe_dashboard_file_stat(path: Path) -> tuple[int, int, int]:
+    """Return (size_bytes, char_count, entry_count) without exposing contents."""
+    if not path.exists() or not path.is_file():
+        return 0, 0, 0
+    try:
+        text = path.read_text(encoding="utf-8", errors="replace")
+        size_bytes = path.stat().st_size
+    except OSError:
+        return 0, 0, 0
+    stripped = text.strip()
+    if not stripped:
+        return size_bytes, 0, 0
+    entries = [item for item in text.split("\n§\n") if item.strip()]
+    return size_bytes, len(text), len(entries)
+
+
+def _memory_bucket_usage(path: Path, limit: int) -> Dict[str, Any]:
+    size_bytes, chars, entries = _safe_dashboard_file_stat(path)
+    usage_percent = None
+    if limit > 0:
+        usage_percent = min(100.0, round((chars / limit) * 100, 2))
+    return {
+        "entries": entries,
+        "chars": chars,
+        "limit": limit,
+        "usage_percent": usage_percent,
+        "size_bytes": size_bytes,
+        "exists": path.exists(),
+    }
+
+
+def _safe_dashboard_directory_size(root: Path, *, excluded_names: Optional[set[str]] = None) -> int:
+    """Best-effort byte count for local provider storage, excluding config/secret files."""
+    if not root.exists() or not root.is_dir():
+        return 0
+    excluded = excluded_names or set()
+    total = 0
+    try:
+        paths = list(root.rglob("*"))
+    except OSError:
+        return 0
+    for path in paths:
+        if not path.is_file() or path.name in excluded:
+            continue
+        try:
+            total += path.stat().st_size
+        except OSError:
+            continue
+    return total
+
+
+def _read_dashboard_hindsight_config(profile_dir: Path) -> Dict[str, Any]:
+    config_path = profile_dir / "hindsight" / "config.json"
+    if not config_path.exists():
+        return {}
+    try:
+        raw = json.loads(config_path.read_text(encoding="utf-8"))
+    except Exception:
+        return {}
+    return raw if isinstance(raw, dict) else {}
+
+
+def _hindsight_budget(config: Dict[str, Any]) -> Optional[str]:
+    banks = config.get("banks")
+    if isinstance(banks, dict):
+        for bank in banks.values():
+            if not isinstance(bank, dict):
+                continue
+            if bank.get("enabled", True) is False:
+                continue
+            budget = bank.get("budget")
+            if budget:
+                return str(budget)
+    budget = config.get("recall_budget") or config.get("budget")
+    return str(budget) if budget else None
+
+
+def _hindsight_bank_id(config: Dict[str, Any]) -> str:
+    bank_id = config.get("bank_id") or config.get("bankId")
+    if bank_id:
+        return str(bank_id)
+    banks = config.get("banks")
+    if isinstance(banks, dict):
+        for bank in banks.values():
+            if not isinstance(bank, dict):
+                continue
+            if bank.get("enabled", True) is False:
+                continue
+            bank_id = bank.get("bankId") or bank.get("bank_id")
+            if bank_id:
+                return str(bank_id)
+    return "hermes"
+
+
+def _hindsight_api_url(config: Dict[str, Any]) -> str:
+    return str(config.get("api_url") or config.get("apiUrl") or "https://api.hindsight.vectorize.io")
+
+
+def _safe_dashboard_endpoint_label(url: str) -> str:
+    try:
+        parsed = urllib.parse.urlparse(url)
+    except Exception:
+        return "configured endpoint"
+    return parsed.netloc or parsed.path or "configured endpoint"
+
+
+def _probe_dashboard_hindsight_memory_stats(api_url: str, bank_id: str, timeout: float = 2.0) -> Dict[str, Any]:
+    """Return safe Hindsight bank metadata without exposing memory contents."""
+    try:
+        from hindsight_client import Hindsight  # type: ignore
+    except Exception as exc:
+        return {
+            "record_count": None,
+            "usage_state": "unknown",
+            "source": "hindsight_client",
+            "error": f"hindsight client unavailable: {type(exc).__name__}",
+        }
+
+    client = None
+    try:
+        client = Hindsight(base_url=api_url, timeout=float(timeout))
+        response = client.list_memories(bank_id=bank_id, limit=1, offset=0)
+        total = getattr(response, "total", None)
+        if isinstance(total, int):
+            return {
+                "record_count": total,
+                "usage_state": "tracked",
+                "source": "hindsight_api",
+            }
+        return {
+            "record_count": None,
+            "usage_state": "unknown",
+            "source": "hindsight_api",
+            "error": "hindsight response did not include total",
+        }
+    except Exception as exc:
+        return {
+            "record_count": None,
+            "usage_state": "unknown",
+            "source": "hindsight_api",
+            "error": f"hindsight stats unavailable: {type(exc).__name__}",
+        }
+    finally:
+        if client is not None:
+            try:
+                client.close()
+            except Exception:
+                pass
+
+
+def _dashboard_external_memory_summary(
+    profile_dir: Path,
+    provider: Optional[str],
+    external_cache: Optional[Dict[Tuple[str, str, str], Dict[str, Any]]] = None,
+) -> Optional[Dict[str, Any]]:
+    if not provider:
+        return None
+    provider_name = str(provider)
+    if provider_name == "hindsight":
+        cfg = _read_dashboard_hindsight_config(profile_dir)
+        mode = str(cfg.get("mode") or "cloud")
+        api_url = _hindsight_api_url(cfg)
+        bank_id = _hindsight_bank_id(cfg)
+        storage_type = "cloud" if mode == "cloud" else "external_api"
+        endpoint_label = _safe_dashboard_endpoint_label(api_url)
+        local_bytes = 0
+        cache_key = (provider_name, api_url, bank_id)
+        if mode == "cloud" and not (cfg.get("apiKey") or cfg.get("api_key") or os.getenv("HINDSIGHT_API_KEY")):
+            stats = {
+                "record_count": None,
+                "usage_state": "unknown",
+                "source": "hindsight_api",
+                "error": "hindsight cloud api key unavailable",
+            }
+        elif external_cache is not None and cache_key in external_cache:
+            stats = external_cache[cache_key]
+        else:
+            timeout = float(cfg.get("timeout") or 2.0)
+            stats = _probe_dashboard_hindsight_memory_stats(api_url, bank_id, timeout=min(timeout, 2.0))
+            if external_cache is not None:
+                external_cache[cache_key] = stats
+
+        if mode in {"local", "local_embedded"}:
+            local_bytes = _safe_dashboard_directory_size(
+                profile_dir / "hindsight",
+                excluded_names={"config.json", ".env"},
+            )
+        record_count = stats.get("record_count") if isinstance(stats, dict) else None
+        if isinstance(record_count, int):
+            usage_state = "tracked"
+        elif local_bytes:
+            usage_state = "tracked"
+        else:
+            usage_state = str((stats or {}).get("usage_state") or "unknown")
+        return {
+            "provider": provider_name,
+            "mode": mode,
+            "storage_type": storage_type,
+            "bank_id": bank_id,
+            "endpoint": endpoint_label,
+            "source_key": f"{provider_name}|{endpoint_label}|{bank_id}",
+            "budget": _hindsight_budget(cfg),
+            "storage_bytes": local_bytes,
+            "record_count": record_count if isinstance(record_count, int) else None,
+            "usage_percent": None,
+            "usage_state": usage_state,
+            "source": (stats or {}).get("source"),
+            "error": (stats or {}).get("error"),
+        }
+    provider_dir = profile_dir / provider_name
+    local_bytes = _safe_dashboard_directory_size(
+        provider_dir,
+        excluded_names={"config.json", ".env"},
+    )
+    return {
+        "provider": provider_name,
+        "mode": "unknown",
+        "storage_type": "local" if local_bytes else "unknown",
+        "budget": None,
+        "storage_bytes": local_bytes,
+        "record_count": None,
+        "usage_percent": None,
+        "usage_state": "tracked" if local_bytes else "unknown",
+    }
+
+
+def _dashboard_profile_memory_summary(
+    profile: str,
+    profile_dir: Path,
+    external_cache: Optional[Dict[Tuple[str, str, str], Dict[str, Any]]] = None,
+) -> Dict[str, Any]:
+    config = _read_dashboard_profile_config(profile_dir)
+    mem_cfg = config.get("memory") if isinstance(config.get("memory"), dict) else {}
+    if not isinstance(mem_cfg, dict):
+        mem_cfg = {}
+    enabled = bool(mem_cfg.get("memory_enabled", DEFAULT_CONFIG["memory"].get("memory_enabled", True)))
+    user_profile_enabled = bool(mem_cfg.get(
+        "user_profile_enabled",
+        DEFAULT_CONFIG["memory"].get("user_profile_enabled", True),
+    ))
+    external_provider_raw = mem_cfg.get("provider", DEFAULT_CONFIG["memory"].get("provider", ""))
+    external_provider = str(external_provider_raw).strip() or None
+    provider = external_provider or "builtin"
+    memory_limit = int(mem_cfg.get("memory_char_limit", DEFAULT_CONFIG["memory"].get("memory_char_limit", 2200)) or 0)
+    user_limit = int(mem_cfg.get("user_char_limit", DEFAULT_CONFIG["memory"].get("user_char_limit", 1375)) or 0)
+
+    memories_dir = profile_dir / "memories"
+    memory_bucket = _memory_bucket_usage(memories_dir / "MEMORY.md", memory_limit)
+    user_bucket = _memory_bucket_usage(memories_dir / "USER.md", user_limit)
+    builtin_storage_bytes = int(memory_bucket["size_bytes"] or 0) + int(user_bucket["size_bytes"] or 0)
+    builtin_record_count = int(memory_bucket["entries"] or 0) + int(user_bucket["entries"] or 0)
+    external = _dashboard_external_memory_summary(profile_dir, external_provider, external_cache)
+    external_storage_bytes = int((external or {}).get("storage_bytes") or 0)
+    external_record_count = (external or {}).get("record_count")
+
+    usage_state = "disabled" if not enabled else "tracked"
+    if enabled and external_provider and (external or {}).get("usage_state") == "unknown":
+        usage_state = "partial" if builtin_record_count or builtin_storage_bytes else "unknown"
+
+    return {
+        "profile": profile,
+        "enabled": enabled,
+        "user_profile_enabled": user_profile_enabled,
+        "provider": provider,
+        "external_provider": external_provider,
+        "builtin_provider": "builtin",
+        "local_record_count": builtin_record_count,
+        "builtin": {
+            "provider": "builtin",
+            "storage_type": "local_files",
+            "storage_bytes": builtin_storage_bytes,
+            "record_count": builtin_record_count,
+            "memory": memory_bucket,
+            "user": user_bucket,
+            "usage_state": "tracked" if builtin_storage_bytes or builtin_record_count else "empty",
+        },
+        "external": external,
+        "storage_bytes": builtin_storage_bytes + external_storage_bytes,
+        "known_record_count": builtin_record_count + (int(external_record_count) if isinstance(external_record_count, int) else 0),
+        "usage_percent": None,
+        "usage_state": usage_state,
+    }
+
+
+def _dashboard_memory_overview(memory_rows: List[Dict[str, Any]]) -> Dict[str, Any]:
+    providers: Dict[str, Dict[str, Any]] = {}
+    external_banks_by_key: Dict[str, Dict[str, Any]] = {}
+    provider_seen_sources: Dict[str, set[str]] = {}
+    enabled_rows = [row for row in memory_rows if row.get("enabled")]
+    builtin_storage_bytes = 0
+    builtin_record_count = 0
+
+    for row in enabled_rows:
+        builtin_bucket = providers.setdefault("builtin", {
+            "provider": "builtin",
+            "profiles": 0,
+            "storage_bytes": 0,
+            "known_record_count": 0,
+            "usage_state": "tracked",
+        })
+        builtin_bucket["profiles"] += 1
+        source = row.get("builtin") or {}
+        local_bytes = int(source.get("storage_bytes") or 0)
+        local_records = int(source.get("record_count") or 0)
+        builtin_storage_bytes += local_bytes
+        builtin_record_count += local_records
+        builtin_bucket["storage_bytes"] += local_bytes
+        builtin_bucket["known_record_count"] += local_records
+
+        provider_name = row.get("external_provider")
+        external = row.get("external") or {}
+        if not provider_name or not isinstance(external, dict):
+            continue
+        name = str(provider_name)
+        bucket = providers.setdefault(name, {
+            "provider": name,
+            "profiles": 0,
+            "storage_bytes": 0,
+            "known_record_count": 0,
+            "usage_state": "tracked",
+        })
+        bucket["profiles"] += 1
+        source_key = str(
+            external.get("source_key")
+            or f"{name}|{external.get('endpoint') or ''}|{external.get('bank_id') or row.get('profile') or ''}"
+        )
+        if source_key not in external_banks_by_key:
+            external_banks_by_key[source_key] = {
+                "provider": name,
+                "mode": external.get("mode"),
+                "bank_id": external.get("bank_id"),
+                "endpoint": external.get("endpoint"),
+                "budget": external.get("budget"),
+                "storage_type": external.get("storage_type"),
+                "storage_bytes": int(external.get("storage_bytes") or 0),
+                "record_count": external.get("record_count") if isinstance(external.get("record_count"), int) else None,
+                "usage_percent": external.get("usage_percent"),
+                "usage_state": external.get("usage_state") or "unknown",
+                "profiles": [],
+                "source": external.get("source"),
+                "error": external.get("error"),
+            }
+        bank = external_banks_by_key[source_key]
+        profile = str(row.get("profile") or "")
+        if profile and profile not in bank["profiles"]:
+            bank["profiles"].append(profile)
+
+        seen = provider_seen_sources.setdefault(name, set())
+        if source_key not in seen:
+            seen.add(source_key)
+            bucket["storage_bytes"] += int(external.get("storage_bytes") or 0)
+            record_count = external.get("record_count")
+            if isinstance(record_count, int):
+                bucket["known_record_count"] += record_count
+            if external.get("usage_state") == "unknown":
+                bucket["usage_state"] = "unknown"
+
+    external_banks = sorted(
+        external_banks_by_key.values(),
+        key=lambda item: (
+            str(item.get("provider") or ""),
+            str(item.get("endpoint") or ""),
+            str(item.get("bank_id") or ""),
+        ),
+    )
+    for bank in external_banks:
+        bank["profiles"] = sorted(bank.get("profiles") or [])
+        bank["profile_count"] = len(bank["profiles"])
+
+    external_storage_bytes = sum(int(bank.get("storage_bytes") or 0) for bank in external_banks)
+    external_record_count = sum(
+        int(bank.get("record_count") or 0)
+        for bank in external_banks
+        if isinstance(bank.get("record_count"), int)
+    )
+    storage_bytes = builtin_storage_bytes + external_storage_bytes
+    known_record_count = builtin_record_count + external_record_count
+    if not enabled_rows:
+        usage_state = "disabled"
+    elif any(bank.get("usage_state") == "unknown" for bank in external_banks):
+        usage_state = "partial" if known_record_count or storage_bytes else "unknown"
+    else:
+        usage_state = "tracked"
+
+    return {
+        "enabled_profiles": len(enabled_rows),
+        "disabled_profiles": len(memory_rows) - len(enabled_rows),
+        "user_profile_enabled_profiles": sum(1 for row in memory_rows if row.get("user_profile_enabled")),
+        "providers": sorted(providers.values(), key=lambda item: str(item.get("provider") or "")),
+        "external_banks": external_banks,
+        "rows": memory_rows,
+        "storage_bytes": storage_bytes,
+        "known_record_count": known_record_count,
+        "local_record_count": builtin_record_count,
+        "external_record_count": external_record_count,
+        "usage_percent": None,
+        "usage_state": usage_state,
+    }
+
