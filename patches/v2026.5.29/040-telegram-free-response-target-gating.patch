+def _should_redact_source_pii(source: SessionSource, redact_pii: bool) -> bool:
+    """Return True when this source's stable IDs should be hidden from prompts."""
+    if not redact_pii:
+        return False
+
+    # Only apply redaction on platforms where IDs aren't needed for mentions.
+    # Check both the hardcoded set (builtins) and the plugin registry.
+    if source.platform in _PII_SAFE_PLATFORMS:
+        return True
+    try:
+        from gateway.platform_registry import platform_registry
+
+        entry = platform_registry.get(source.platform.value)
+        return bool(entry and entry.pii_safe)
+    except Exception:
+        return False
+
