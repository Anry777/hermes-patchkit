+"""NeuroGate provider profile."""
+
+from providers import register_provider
+from providers.base import ProviderProfile
+
+
+neurogate = ProviderProfile(
+    name="neurogate",
+    aliases=("neurogate-space", "neurogate-api"),
+    display_name="NeuroGate",
+    description="OpenAI Responses-compatible proxy for GPT-5.x models",
+    signup_url="https://neurogate.space/",
+    api_mode="codex_responses",
+    env_vars=("NEUROGATE_API_KEY", "NEUROGATE_BASE_URL"),
+    base_url="https://api.neurogate.space/v1",
+    auth_type="api_key",
+    default_aux_model="gpt-5.4-mini",
+    fallback_models=(
+        "gpt-5.5",
+        "gpt-5.4",
+        "gpt-5.4-mini",
+        "gpt-5.3-codex",
+    ),
+)
+
+register_provider(neurogate)
