     return get_hermes_home() / "config.yaml"
 
 
+def resolve_auth_store_path() -> Path:
+    """Return the single shared Hermes ``auth.json`` path.
+
+    Profiles isolate config, sessions, skills, memory, and logs, but provider
+    OAuth state and credential pools are account-level resources.  Keep them in
+    the root Hermes home so token refresh, credential rotation, exhaustion
+    markers, and manual credential additions are visible to every profile.
+    """
+    return get_default_hermes_root() / "auth.json"
+
+
 def get_skills_dir() -> Path:
