+def _auth_writer_code_mtime() -> float:
+    """Return a conservative freshness marker for auth/pool writer code."""
+    candidates = [
+        Path(__file__),
+        Path(__file__).with_name("auth_commands.py"),
+        Path(__file__).resolve().parents[1] / "agent" / "credential_pool.py",
+    ]
+    mtimes: List[float] = []
+    for path in candidates:
