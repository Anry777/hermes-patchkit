+            "api_call_count": 3,
+            "max_iterations": 50,
+            "last_activity_desc": "waiting for API response",
+        }
+
+        def slow_run(**kwargs):
+            time.sleep(0.6)
+            return {"final_response": "done", "completed": True, "api_calls": 3}
+
+        child.run_conversation.side_effect = slow_run
+
+        from tools import delegate_tool
+
+        # At interval 0.05s, idle threshold trips well before 0.8s.
+        # We should see the heartbeat stop firing before the child completes.
