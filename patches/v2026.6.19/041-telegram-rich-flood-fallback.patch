+@pytest.mark.asyncio
+async def test_rich_retry_after_falls_back_to_legacy_send_path():
+    """RetryAfter is a pre-delivery rejection, so legacy resend is safe.
+
+    The legacy path owns sleeping for Telegram's retry window. Returning a
+    retryable rich failure here would make BasePlatformAdapter retry too early
+    and eventually surface "Message delivery failed" even though the answer was
+    generated.
+    """
+    adapter = _make_adapter()
+    bot = adapter._bot
+    assert bot is not None
+    bot.do_api_request = AsyncMock(side_effect=RetryAfter(20))
+
+    result = await adapter.send("12345", RICH_CONTENT)
+
+    assert result.success is True
+    bot.do_api_request.assert_awaited_once()
+    bot.send_message.assert_awaited()
+
+
+@pytest.mark.asyncio
+async def test_rich_flood_control_text_falls_back_to_legacy_send_path():
+    adapter = _make_adapter()
+    bot = adapter._bot
+    assert bot is not None
+    bot.do_api_request = AsyncMock(
+        side_effect=RuntimeError("Flood control exceeded. Retry in 20 seconds")
+    )
+
+    result = await adapter.send("12345", RICH_CONTENT)
+
+    assert result.success is True
+    bot.send_message.assert_awaited()
+
+
