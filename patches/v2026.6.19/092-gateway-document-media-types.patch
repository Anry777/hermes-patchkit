+def _env_flag_enabled(env_var: str, default: bool = False) -> bool:
+    """Return a boolean feature flag from common env truthy/falsy strings."""
+    raw = os.environ.get(env_var)
+    if raw is None:
+        return default
+    normalized = raw.strip().lower()
+    if normalized in ("1", "true", "yes", "on"):
+        return True
+    if normalized in ("0", "false", "no", "off", ""):
+        return False
+    return default
+
