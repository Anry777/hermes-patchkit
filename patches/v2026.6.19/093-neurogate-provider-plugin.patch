diff --git a/tests/hermes_cli/test_neurogate_auth.py b/tests/hermes_cli/test_neurogate_auth.py
new file mode 100644
index 000000000..434ad4666
--- /dev/null
+++ b/tests/hermes_cli/test_neurogate_auth.py
@@ -0,0 +1,43 @@
+"""Tests for NeuroGate auth and runtime provider wiring."""
+
+from __future__ import annotations
+
+import json
+
+
+def test_auth_add_neurogate_api_key_resolves_responses_runtime(tmp_path, monkeypatch):
+    hermes_home = tmp_path / "hermes"
+    hermes_home.mkdir(parents=True, exist_ok=True)
+    (hermes_home / "auth.json").write_text(json.dumps({"version": 1, "providers": {}}))
+    monkeypatch.setenv("HERMES_HOME", str(hermes_home))
+    monkeypatch.delenv("NEUROGATE_API_KEY", raising=False)
+    monkeypatch.delenv("NEUROGATE_BASE_URL", raising=False)
+
+    from hermes_cli.auth import PROVIDER_REGISTRY, resolve_provider
+    from hermes_cli.auth_commands import auth_add_command
+    from hermes_cli.runtime_provider import resolve_runtime_provider
+
+    assert resolve_provider("neurogate") == "neurogate"
+    assert "neurogate-space" not in PROVIDER_REGISTRY
+    assert "neurogate-api" not in PROVIDER_REGISTRY
+    assert "neurogate" in PROVIDER_REGISTRY
+
+    class _Args:
+        provider = "neurogate"
+        auth_type = "api-key"
+        api_key = "ng-test-key"
+        label = "ng"
+
+    auth_add_command(_Args())
+
+    payload = json.loads((hermes_home / "auth.json").read_text())
+    entry = payload["credential_pool"]["neurogate"][0]
+    assert entry["label"] == "ng"
+    assert entry["access_token"] == "ng-test-key"
+    assert entry["base_url"] == "https://api.neurogate.space/v1"
+
+    runtime = resolve_runtime_provider(requested="neurogate")
+    assert runtime["provider"] == "neurogate"
+    assert runtime["api_mode"] == "codex_responses"
+    assert runtime["base_url"] == "https://api.neurogate.space/v1"
+    assert runtime["api_key"] == "ng-test-key"
