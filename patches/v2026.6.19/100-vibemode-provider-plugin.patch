+        value = self._lookup_model_map(self.model_api_modes, model)
+        if isinstance(value, str):
+            normalized = value.strip().lower()
+            if normalized in {
+                "chat_completions",
+                "codex_responses",
+                "anthropic_messages",
+                "bedrock_converse",
+                "codex_app_server",
+            }:
+                return normalized
+        return None
+
+    def get_model_capabilities(self, model: str | None) -> tuple[str, ...]:
