+                "cmd": "/root/.local/bin/hermes --resume old -p hermesfix",
+                "started_at": 1710000000.0,
+            }
+        ],
+        raising=False,
+    )
+
+    def _device_flow_should_not_start():  # pragma: no cover - failure path only
+        raise AssertionError("device-code login should not start while stale writers exist")
