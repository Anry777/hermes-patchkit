+        if isinstance(value, str) and value.strip():
+            return value.strip()
+    profile = claims.get("https://api.openai.com/profile")
+    if isinstance(profile, dict):
+        for key in ("email", "username", "name"):
+            value = profile.get(key)
+            if isinstance(value, str) and value.strip():
+                return value.strip()
+    return fallback
+
+
+def _auth_writer_code_mtime() -> float:
+    """Return a conservative freshness marker for auth/pool writer code."""
+    candidates = [
+        Path(__file__),
+        Path(__file__).with_name("auth_commands.py"),
+        Path(__file__).resolve().parents[1] / "agent" / "credential_pool.py",
+    ]
+    mtimes: List[float] = []
+    for path in candidates:
+        try:
+            mtimes.append(path.stat().st_mtime)
+        except OSError:
+            continue
+    return max(mtimes) if mtimes else time.time()
+
+
+def _proc_start_time(pid: int, proc_root: Path) -> Optional[float]:
+    try:
+        uptime = float((proc_root / "uptime").read_text().split()[0])
+        boot_time = time.time() - uptime
+        stat_text = (proc_root / str(pid) / "stat").read_text(errors="replace")
+        after_comm = stat_text.rsplit(") ", 1)[1].split()
+        # /proc/<pid>/stat field 22 is starttime.  after_comm[0] is field 3.
+        start_ticks = int(after_comm[19])
+        ticks_per_second = os.sysconf(os.sysconf_names.get("SC_CLK_TCK", "SC_CLK_TCK"))
+        return boot_time + (start_ticks / float(ticks_per_second))
+    except Exception:
+        return None
+
+
+def _proc_cmdline(pid: int, proc_root: Path) -> List[str]:
+    try:
+        raw = (proc_root / str(pid) / "cmdline").read_bytes()
+    except OSError:
+        return []
+    return [part.decode(errors="replace") for part in raw.split(b"\0") if part]
+
+
+def _proc_environ(pid: int, proc_root: Path) -> Dict[str, str]:
+    try:
+        raw = (proc_root / str(pid) / "environ").read_bytes()
+    except OSError:
+        return {}
+    env: Dict[str, str] = {}
+    for item in raw.split(b"\0"):
+        if b"=" not in item:
+            continue
+        key, value = item.split(b"=", 1)
+        env[key.decode(errors="replace")] = value.decode(errors="replace")
+    return env
+
+
+def _auth_root_from_env(env: Dict[str, str]) -> Optional[Path]:
+    hermes_home = str(env.get("HERMES_HOME") or "").strip()
+    if hermes_home:
+        path = Path(hermes_home)
+        if path.parent.name == "profiles":
+            return path.parent.parent
+        return path
+    home = str(env.get("HOME") or "").strip()
+    if home:
+        return Path(home) / ".hermes"
+    return None
+
+
+def _same_auth_root_as_current(pid: int, proc_root: Path) -> bool:
+    other_root = _auth_root_from_env(_proc_environ(pid, proc_root))
+    if other_root is None:
+        return True
+    try:
+        current_root = resolve_auth_store_path().parent
+        return other_root.expanduser().resolve() == current_root.expanduser().resolve()
+    except OSError:
+        return other_root.expanduser() == resolve_auth_store_path().parent.expanduser()
+
+
+def _is_hermes_auth_writer_command(parts: List[str]) -> bool:
+    if not parts:
+        return False
+    cmd = " ".join(parts)
+    if "search_mcp.py" in cmd:
+        return False
+    if "hermes_cli.main" in parts:
+        return True
+    for part in parts:
+        base = Path(part).name
+        if base == "hermes" or part.endswith("/.local/bin/hermes"):
+            return True
+    return "hermes-agent" in cmd and "hermes" in cmd
+
+
+def find_stale_auth_writer_processes(
+    *,
+    reference_mtime: Optional[float] = None,
+    proc_root: Path = Path("/proc"),
+) -> List[Dict[str, Any]]:
+    """Find live Hermes processes that started before the current auth-writer code.
+
+    A fresh ``auth add openai-codex`` can be erased after success by any older
+    long-lived Hermes process that still has pre-merge-safe CredentialPool code
+    in memory.  Detect those processes before spending the device-code login.
+    """
+    if sys.platform != "linux" or is_truthy_value(os.getenv("HERMES_AUTH_ALLOW_STALE_WRITERS")):
+        return []
+    if not proc_root.exists():
+        return []
+    marker = float(reference_mtime if reference_mtime is not None else _auth_writer_code_mtime())
+    current_pid = os.getpid()
+    stale: List[Dict[str, Any]] = []
+    for entry in proc_root.iterdir():
+        if not entry.name.isdigit():
+            continue
+        pid = int(entry.name)
+        if pid == current_pid:
+            continue
+        parts = _proc_cmdline(pid, proc_root)
+        if not _is_hermes_auth_writer_command(parts):
+            continue
+        if not _same_auth_root_as_current(pid, proc_root):
+            continue
+        started_at = _proc_start_time(pid, proc_root)
+        if started_at is None:
+            continue
+        if started_at < marker - 1.0:
+            stale.append({
+                "pid": pid,
+                "cmd": " ".join(shlex.quote(part) for part in parts),
+                "started_at": started_at,
+            })
+    stale.sort(key=lambda item: int(item.get("pid") or 0))
+    return stale
+
+
+def format_stale_auth_writer_processes(processes: List[Dict[str, Any]]) -> str:
+    shown = []
+    for proc in processes[:5]:
+        cmd = str(proc.get("cmd") or "")
+        if len(cmd) > 180:
+            cmd = cmd[:177] + "..."
+        shown.append(f"  PID {proc.get('pid')}: {cmd}")
+    extra = len(processes) - len(shown)
+    if extra > 0:
+        shown.append(f"  ... and {extra} more")
+    details = "\n".join(shown)
+    return (
+        "Refusing to add openai-codex credentials while stale Hermes auth writer "
+        "processes are still running. Restart/exit those Hermes CLI, gateway, "
+        "dashboard, or provider-proxy processes first; otherwise they can erase "
+        "the new Codex account after this command prints success.\n"
+        f"{details}\n"
+        "If you intentionally accept that risk for diagnostics only, set "
+        "HERMES_AUTH_ALLOW_STALE_WRITERS=1."
+    )
+
+
+def ensure_no_stale_auth_writers_for_codex_add() -> None:
+    processes = find_stale_auth_writer_processes()
+    if processes:
+        raise SystemExit(format_stale_auth_writer_processes(processes))
+
+
+def _save_codex_pool_entry(
+    tokens: Dict[str, str],
+    last_refresh: Optional[str] = None,
+    label: Optional[str] = None,
+) -> Dict[str, Any]:
+    """Append an independent Codex OAuth account to credential_pool.
+
+    This is intentionally separate from ``_save_codex_tokens()``.  The latter
+    rewrites the singleton ``providers.openai-codex`` login, while provider
+    setup/auth-add flows that mean "add another account" must preserve every
+    existing pool entry and write a unique manual source.
+    """
+    access_token = str(tokens.get("access_token") or "").strip()
+    if not access_token:
+        raise AuthError(
+            "Codex OAuth login did not return an access_token.",
+            provider="openai-codex",
+            code="codex_auth_missing_access_token",
+            relogin_required=True,
+        )
+    refresh_token = str(tokens.get("refresh_token") or "").strip()
+    if last_refresh is None:
+        last_refresh = datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")
+
+    with _auth_store_lock():
+        auth_store = _load_auth_store()
+        pool = auth_store.get("credential_pool")
+        if not isinstance(pool, dict):
+            pool = {}
+            auth_store["credential_pool"] = pool
+        entries = pool.get("openai-codex")
+        if not isinstance(entries, list):
+            entries = []
+            pool["openai-codex"] = entries
+
+        existing_ids = {
+            str(entry.get("id") or "")
+            for entry in entries
+            if isinstance(entry, dict)
+        }
+        entry_id = uuid.uuid4().hex[:6]
+        while entry_id in existing_ids:
+            entry_id = uuid.uuid4().hex[:6]
+
+        priorities = []
+        for idx, entry in enumerate(entries):
+            if not isinstance(entry, dict):
+                continue
+            try:
+                priorities.append(int(entry.get("priority", idx)))
+            except Exception:
+                priorities.append(idx)
+        priority = (max(priorities) + 1) if priorities else 0
+        shown_label = str(label or "").strip() or _codex_pool_label(
+            access_token,
+            f"openai-codex-oauth-{len(entries) + 1}",
+        )
+        entry: Dict[str, Any] = {
+            "id": entry_id,
+            "label": shown_label,
+            "auth_type": "oauth",
+            "priority": priority,
+            "source": f"manual:device_code:{entry_id}",
+            "access_token": access_token,
+            "base_url": DEFAULT_CODEX_BASE_URL,
+            "last_refresh": last_refresh,
+        }
+        if refresh_token:
+            entry["refresh_token"] = refresh_token
+        entries.append(entry)
+        _save_auth_store(auth_store)
+        persisted_store = _load_auth_store()
+        persisted_pool = persisted_store.get("credential_pool")
+        persisted_entries = []
+        if isinstance(persisted_pool, dict):
+            maybe_entries = persisted_pool.get("openai-codex")
+            if isinstance(maybe_entries, list):
+                persisted_entries = maybe_entries
+        if not any(
+            isinstance(item, dict)
+            and item.get("id") == entry_id
+            and item.get("source") == entry["source"]
+            for item in persisted_entries
+        ):
+            raise AuthError(
+                "Codex OAuth credential did not persist to auth.json; no success "
+                "message was printed. Restart stale Hermes processes and retry.",
+                provider="openai-codex",
+                code="codex_auth_add_not_persisted",
+                relogin_required=True,
+            )
+        return dict(entry)
+
