+def test_busy_text_mode_inherits_busy_input_mode_when_absent(gateway_home):
+    """0.14-compatible configs must keep TEXT follow-ups interrupting.
+
+    Before 0.15.1 there was only display.busy_input_mode.  If a profile sets
+    that legacy knob to interrupt and omits the newer busy_text_mode, ordinary
+    TEXT follow-ups should inherit interrupt instead of silently queueing.
+    """
+    _write_config(gateway_home, "display:\n  busy_input_mode: interrupt\n")
+
+    assert gateway_run.GatewayRunner._load_busy_text_mode() == "interrupt"
+
+
+def test_busy_text_mode_explicit_queue_overrides_busy_input_mode(gateway_home):
+    _write_config(
+        gateway_home,
+        "display:\n  busy_input_mode: interrupt\n  busy_text_mode: queue\n",
+    )
+
+    assert gateway_run.GatewayRunner._load_busy_text_mode() == "queue"
+
+
 
